---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Contacto">
  <section class="relative min-h-screen overflow-hidden px-6 pb-24 pt-20 text-white">
    <!-- FONDO -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-[30rem] w-[30rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.04] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl">
      <!-- HEADER -->
      <header class="text-center mb-12">
        <h1 class="es-page-title mb-4 text-4xl md:text-5xl">
          Contacto
        </h1>

        <p class="text-sm text-white/60 max-w-xl mx-auto leading-relaxed">
          Si sentís que algo de este universo resuena con vos, consultá.
          No hace falta llegar con todo resuelto.
        </p>

        <div class="es-divider mx-auto mt-8 w-32"></div>
      </header>

      <!-- FORMULARIO -->
      <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
        <p class="eyebrow-ritual mb-3">
          Enviar mensaje
        </p>

        <h2 class="titulo-ritual mb-6">
          Abrir una conversación
        </h2>

        <div class="space-y-5">
          <!-- ORIENTACIÓN INTEGRADA -->
          <div class="subpanel-soft rounded-[1.7rem] px-5 py-5">
            <label for="motivo" class="block">
              <p class="eyebrow-mini mb-3">
                ¿Sobre qué querés escribir?
              </p>

              <select
                id="motivo"
                class="w-full rounded-[1.2rem] border border-[#ecdcb8]/10 bg-[#0a0610]/70 px-4 py-3 text-white/80 outline-none transition duration-300 focus:border-[#ecdcb8]/20"
              >
                <option value="">Elegir una opción</option>
                <option value="Quiero vivir un viaje sonoro.">
                  Quiero vivir un viaje sonoro
                </option>
                <option value="Me interesa una experiencia grupal.">
                  Me interesa una experiencia grupal
                </option>
                <option value="Quiero saber más sobre los sahumerios.">
                  Quiero saber más sobre los sahumerios
                </option>
                <option value="Estoy buscando algo pero no sé bien qué.">
                  Estoy buscando algo pero no sé bien qué
                </option>
                <option value="Quiero hacer una consulta personal.">
                  Quiero hacer una consulta personal
                </option>
              </select>
            </label>

            <p class="mt-4 text-sm leading-relaxed text-white/58">
              Elegir una opción puede ayudarte a empezar. Después podés escribir con tus propias palabras.
            </p>
          </div>

          <!-- CAMPOS -->
          <div class="space-y-5">
            <input
              type="text"
              placeholder="Nombre"
              class="w-full rounded-[1.4rem] bg-[#0a0610]/80 border border-[#ecdcb8]/10 px-4 py-3 text-white/80 placeholder:text-white/40 focus:outline-none focus:border-[#ecdcb8]/20 transition"
            />

            <input
              type="email"
              placeholder="Email"
              class="w-full rounded-[1.4rem] bg-[#0a0610]/80 border border-[#ecdcb8]/10 px-4 py-3 text-white/80 placeholder:text-white/40 focus:outline-none focus:border-[#ecdcb8]/20 transition"
            />

            <textarea
              id="mensaje"
              rows="5"
              placeholder="Mensaje..."
              class="w-full rounded-[1.4rem] bg-[#0a0610]/80 border border-[#ecdcb8]/10 px-4 py-3 text-white/80 placeholder:text-white/40 focus:outline-none focus:border-[#ecdcb8]/20 transition resize-none"
            ></textarea>
          </div>
        </div>

        <!-- BOTONES -->
        <div class="mt-6 flex flex-col gap-3">
          <a
            href="https://wa.me/1125171969"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-principal text-center"
          >
            Enviar por WhatsApp
          </a>

          <a
            href="mailto:espiritusonicoviajero@gmail.com"
            class="cta-viaje text-center"
          >
            Enviar por Email
          </a>
        </div>
      </section>

      <!-- REDES -->
      <section class="mt-8 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-[#ecdcb8]/50 mb-4">
          También podés escribir por acá
        </p>

        <a
          href="https://instagram.com/espiritu.sonico"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#ecdcb8] hover:text-white transition"
        >
          Instagram
        </a>
      </section>
    </div>
  </section>

  <script>
    const initContacto = () => {
      const motivo = document.getElementById("motivo");
      const mensaje = document.getElementById("mensaje");

      if (!motivo || !mensaje) return;

      motivo.addEventListener("change", () => {
        const value = motivo.value?.trim();
        if (!value) return;

        if (!mensaje.value.trim()) {
          mensaje.value = value + " ";
          mensaje.focus();
          mensaje.setSelectionRange(mensaje.value.length, mensaje.value.length);
        }
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initContacto, { once: true });
    } else {
      initContacto();
    }
  </script>
</Layout>