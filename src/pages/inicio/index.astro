---
import Layout from "../../layouts/Layout.astro";
---
<Layout>
  <section class="min-h-screen flex flex-col items-center justify-start px-0 pt-6 sm:pt-8 text-center text-gold font-serif relative z-10 space-y-10 sm:space-y-14 overflow-x-hidden">

  <!-- Título -->
  <header class="es-page-header animate-fadeInRitual px-4">
  <h1 class="es-page-title mx-auto max-w-4xl text-3xl leading-tight sm:text-4xl md:text-5xl">
    Espíritu Sónico
  </h1>

  <p class="italic es-subtitle mx-auto mt-5 max-w-3xl text-[17px] md:text-[19px]">
  Un sitio donde viajes sonoros, símbolo, materia y tecnología
  <br class="hidden md:block" />
  trabajan juntos para abrir otros estados.
</p>

  <div class="es-divider mx-auto mt-8 w-32"></div>
</header>

<p class="es-instruction mt-4 text-center">
  <span class="md:hidden">Deslizá para recorrer el Universo</span>
  <span class="hidden md:inline">Usá las flechas para recorrer el Universo</span>
</p>
</header>

  <!-- Carrusel Coverflow -->
  <div class="relative w-full max-w-[1000px] mx-auto overflow-visible">
    <div id="carousel-track" class="relative flex items-center justify-center min-h-[260px] sm:min-h-[300px] opacity-0 transition-opacity duration-300">
      {[
        { title: "Tienda", icon: "/iconos/icon-sahumerio.png", link: "/tienda" },
        { title: "Viajes Sonoros", icon: "/iconos/icon-viaje.png", link: "/viajes" },
        { title: "Universo Espíritu Sónico", icon: "/iconos/icon-universo.png", link: "/universo" },
        { title: "Reserva tu experiencia", icon: "/iconos/icon-reserva.png", link: "/contacto" },
        { title: "Cursos y Formaciones", icon: "/iconos/icon-formaciones.png", link: "/formaciones" },
      ].map((item) => (
        <a href={item.link} class="carousel-card absolute flex flex-col items-center justify-center text-center transition-all duration-700 ease-in-out">
          <div class="rounded-2xl bg-[rgba(75,44,94,0.4)] border border-gold/20 shadow-[0_0_30px_rgba(236,220,184,0.1)] backdrop-blur-sm px-6 py-4 w-[180px] sm:w-[200px] md:w-[220px] aspect-square flex flex-col items-center justify-center transition-all duration-700 ease-in-out">
            <img src={item.icon} alt={item.title} class="w-16 h-16 mb-4 object-contain transition-transform duration-700" />
            <h3 class="text-sm md:text-base font-cinzel text-[#f8e9c5] tracking-wider leading-snug">{item.title}</h3>
          </div>
        </a>
      ))}
      <!-- Flechas navegación (solo en desktop) -->
<div class="hidden md:flex absolute top-1/2 -translate-y-1/2 justify-between w-full px-4 pointer-events-none z-20">
  <button id="prev-button" class="pointer-events-auto text-gold text-4xl md:text-5xl hover:scale-110 transition-transform duration-300 px-2">
  ‹
</button>
<button id="next-button" class="pointer-events-auto text-gold text-4xl md:text-5xl hover:scale-110 transition-transform duration-300 px-2">
  ›
</button>
</div>

    </div>
  </div>
</section>

  <script type="module">
  import { initCoverflowCarousel } from '/scripts/coverflow.js';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCoverflowCarousel, { once: true });
  } else {
    initCoverflowCarousel();
  }
</script>
</Layout>
