/* =========================
   MOBILE / TABLET
========================= */

.portal-card {
  position: relative;
  border: none;
  background: transparent;
  padding: 0;
  height: 180px;
  cursor: pointer;
}

.portal-card__inner {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 0.5rem;
  padding: 1rem 1rem 0.95rem;
  background:
    linear-gradient(180deg, rgba(236, 220, 184, 0.045) 0%, rgba(236, 220, 184, 0.015) 100%),
    rgba(18, 10, 24, 0.82);
  border: 1px solid rgba(236, 220, 184, 0.12);
  box-shadow:
    inset 0 1px 0 rgba(236, 220, 184, 0.03),
    0 10px 60px rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  transition:
    transform 0.24s ease,
    box-shadow 0.24s ease,
    border-color 0.24s ease,
    filter 0.24s ease;
}

.portal-card:hover .portal-card__inner {
  transform: translateY(-2px) scale(1.01);
  border-color: rgba(236, 220, 184, 0.22);
  box-shadow:
    inset 0 1px 0 rgba(236, 220, 184, 0.04),
    0 14px 70px rgba(0, 0, 0, 0.24);
  filter: brightness(1.02);
}

.portal-card__label {
  font-size: 0.56rem;
  line-height: 1;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(236,220,184,0.66);
  font-weight: 600;
  text-shadow: 0 0 10px rgba(236,220,184,0.08);
}

.portal-card__title {
  font-size: clamp(0.94rem, 2.6vw, 1.18rem);
  line-height: 1.02;
  color: #f0dfb8;
  font-weight: 500;
  text-wrap: balance;
  align-self: center;
  letter-spacing: 0.012em;
  text-shadow: 0 0 12px rgba(240, 223, 184, 0.08);
}

.portal-card__hint {
  font-size: 0.82rem;
  line-height: 1.08;
  color: rgba(255,255,255,0.72);
  font-weight: 500;
  font-style: italic;
}

.portal-card__content {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 0.5rem;
  padding: 1rem 1rem 0.95rem;
  z-index: 1;
}

.universo-panel--principal {
  transform: scale(1.003);
}

.universo-panel--compacto {
  max-width: none;
  margin-left: 0;
  margin-right: 0;
}

.universo-panel__contenido {
  max-height: 0;
  overflow: hidden;
  transition: max-height 520ms cubic-bezier(0.22, 1, 0.36, 1);
}

.universo-panel.is-open .universo-panel__icon {
  background: rgba(255, 255, 255, 0.08);
  transform: rotate(45deg);
}

.universo-panel__media {
  display: grid;
  gap: 1rem;
  align-content: start;
}

.universo-head {
  margin-bottom: 1.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  padding-bottom: 1rem;
}

.universo-head__title {
  margin-bottom: 0.55rem;
}

.universo-head__summary {
  font-style: italic;
  opacity: 0.75;
}

.subpanel-universo,
.subpanel-soft {
  background:
    radial-gradient(circle at top left, rgba(236, 220, 184, 0.05), transparent 40%),
    rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(14px);
}

.volver-mapa {
  display: inline-flex;
  align-items: center;
  gap: 0.42rem;
  border: none;
  background: transparent;
  color: rgba(255,255,255,0.58);
  font-size: 1rem;
  font-style: italic;
  letter-spacing: 0.01em;
  padding: 0;
  cursor: pointer;
  transition:
    color 220ms ease,
    opacity 220ms ease,
    transform 220ms ease;
  opacity: 0.9;
}

.volver-mapa::before {
  content: "‹";
  font-size: 1.05em;
  line-height: 1;
  color: rgba(236,220,184,0.7);
  transition:
    transform 220ms ease,
    color 220ms ease,
    opacity 220ms ease;
  opacity: 0.85;
}

.volver-mapa:hover {
  color: rgba(255,255,255,0.88);
  transform: translateY(-1px);
}

.volver-mapa:hover::before {
  color: rgba(236,220,184,0.95);
  transform: translateX(-2px);
  opacity: 1;
}

.universo-panel__next {
  appearance: none;
  position: relative;
  border: none;
  background: transparent;
  color: #ecdcb8;
  font-size: 1rem;
  font-style: italic;
  letter-spacing: 0.012em;
  padding: 0 0 0.18rem;
  cursor: pointer;
  transition:
    color 240ms ease,
    transform 240ms ease,
    opacity 240ms ease;
  opacity: 0.94;
}

.universo-panel__next::before {
  content: "";
  position: absolute;
  left: 0;
  right: 1.3rem;
  bottom: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    rgba(236,220,184,0.0) 0%,
    rgba(236,220,184,0.42) 18%,
    rgba(236,220,184,0.85) 55%,
    rgba(236,220,184,0.0) 100%
  );
  transform: scaleX(0.72);
  transform-origin: left center;
  transition:
    transform 260ms ease,
    opacity 260ms ease,
    filter 260ms ease;
  opacity: 0.72;
}

.universo-panel__next::after {
  content: "↗";
  display: inline-block;
  margin-left: 0.42rem;
  font-size: 0.9em;
  line-height: 1;
  transform: translateY(-1px);
  transition:
    transform 240ms ease,
    color 240ms ease,
    opacity 240ms ease;
  opacity: 0.9;
}

.universo-panel__next:hover {
  color: #f2e3bf;
  transform: translateY(-1px);
}

.universo-panel__next:hover::before {
  transform: scaleX(1);
  opacity: 1;
  filter: drop-shadow(0 0 6px rgba(236,220,184,0.22));
}

.universo-panel__next:hover::after {
  transform: translate(3px, -1px);
  opacity: 1;
}

