  transform: scaleX(0.72);
  transform-origin: left center;
  transition:
    transform 260ms ease,
    opacity 260ms ease,
    filter 260ms ease;
  opacity: 0.72;
}

.universo-panel__next::after {
  content: "↗";
  display: inline-block;
  margin-left: 0.42rem;
  font-size: 0.9em;
  line-height: 1;
  transform: translateY(-1px);
