---
import Layout from "../../layouts/Layout.astro";
import { recorridos } from "../../data/universoRecorridos";
---

<Layout title="Universo Espíritu Sónico">
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.025),transparent_45%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <!-- HEADER -->
      <header class="mb-20 text-center">
         <h1 class="titulo-cinzel mx-auto mb-6 max-w-4xl text-4xl leading-tight text-[#ecdcb8] md:text-6xl">
          Universo Espíritu Sónico
        </h1>

        <p class="subtitulo-cormorant mx-auto max-w-3xl text-base leading-relaxed text-white/70 md:text-lg">
          Sonido, símbolo, conciencia y una manera muy concreta de transformar intuición en experiencia.
        </p>

        <div class="mx-auto mt-10 h-px w-32 bg-gradient-to-r from-transparent via-[#ecdcb8]/60 to-transparent"></div>
      </header>

      <!-- PORTAL -->
      <section id="mapa" class="mx-auto mb-16 max-w-6xl">
        <div class="portal-shell rounded-[2.2rem] p-[1px] shadow-[0_18px_76px_rgba(0,0,0,0.34)]">
          <div class="relative rounded-[2.1rem] bg-[#0a0610]/97 px-6 py-7 backdrop-blur-2xl md:px-8 md:py-8">
            <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
              <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
              <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.06] blur-3xl"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.02),transparent_50%)]"></div>
            </div>

            <div class="relative z-10">
              <div class="mx-auto mb-8 max-w-3xl text-center">
                <h2 class="titulo-cinzel mb-3 text-[1.9rem] leading-tight text-[#ecdcb8] md:text-[2.35rem]">
                  Elegí un portal
                </h2>

                <p class="subtitulo-cormorant text-[14px] leading-relaxed text-white/64 md:text-[15px]">
                  Cada acceso abre una dimensión distinta del universo.
                </p>
              </div>

              <div class="portal-wrapper">
                <!-- DESKTOP -->
                <div class="portal-desktop">
                  {recorridos.map((recorrido, index) => (
                    <button
                      type="button"
                      class={`portal-piece portal-piece--${index + 1}`}
                      data-open={recorrido.id}
                    >
                      <span class="portal-piece__bg"></span>

                      <div class="portal-piece__content">
                        <p class="portal-piece__label">{recorrido.portalLabel}</p>
                        <h3 class="portal-piece__title titulo-editorial">{recorrido.titulo}</h3>
                        <p class="portal-piece__hint" set:html={recorrido.portalHint}></p>
                      </div>
                    </button>
                  ))}
                </div>

                <!-- MOBILE / TABLET -->
                <div class="portal-mobile">
                  {recorridos.map((recorrido, index) => (
                    <button
                      type="button"
                      class={`portal-card portal-card--slot-${index + 1}`}
                      data-open={recorrido.id}
                    >
                      <div class="portal-card__inner">
                        <p class="portal-card__label">{recorrido.portalLabel}</p>
                        <h3 class="portal-card__title titulo-editorial">{recorrido.titulo}</h3>
                        <p class="portal-card__hint" set:html={recorrido.portalHint}></p>
                      </div>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- BLOQUES -->
      <section class="space-y-8">
        {recorridos.map((recorrido, index) => (
          <article
            class:list={[
              "universo-panel rounded-[2.2rem] p-[1px] shadow-[0_18px_76px_rgba(0,0,0,0.34)]",
              recorrido.id === "sonologia" && "universo-panel--principal",
              recorrido.id === "simbolo" && "universo-panel--compacto",
            ]}
            data-recorrido={recorrido.id}
          >
            <div class="relative rounded-[2.1rem] bg-[#0a0610]/97 backdrop-blur-2xl">
              <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
                <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.04] blur-3xl"></div>
                <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.05] blur-3xl"></div>
              </div>

              <button
                class="universo-panel__toggle relative z-10 flex w-full items-start justify-between gap-5 px-6 py-7 text-left md:px-8 md:py-8"
                type="button"
                aria-expanded="false"
                aria-controls={`contenido-${recorrido.id}`}
              >
                <div class="min-w-0 universo-head">
                  <p class="mb-3 universo-label">
  {recorrido.portalLabel}
</p>

                  <h2 class="titulo-editorial mb-3 text-3xl leading-tight text-[#ecdcb8] md:text-[2.5rem]">
  {recorrido.titulo}
</h2>

                  <p class="subtitulo-cormorant max-w-4xl text-base leading-relaxed text-white/66 md:text-[1.0625rem]">
                    {recorrido.resumen}
                  </p>
                </div>

                <span class="universo-panel__icon mt-1 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-xl text-[#ecdcb8] transition duration-300">
                  +
                </span>
              </button>

              <div
                id={`contenido-${recorrido.id}`}
                class="universo-panel__contenido"
              >
                <div class:list={[
                  "relative z-10 gap-7 px-6 pb-7 md:px-8 md:pb-8",
                  recorrido.id === "origen" && "grid lg:grid-cols-[1.1fr_0.9fr]",
                  recorrido.id === "musica" && "grid lg:grid-cols-[0.9fr_1.1fr]",
                  recorrido.id === "exploracion" && "mx-auto max-w-4xl",
                  recorrido.id === "sonologia" && "grid lg:grid-cols-[1.05fr_0.95fr] lg:items-center",
                  recorrido.id === "experiencias" && "grid lg:grid-cols-[0.92fr_1.08fr]",
                  recorrido.id === "simbolo" && "mx-auto max-w-6xl",
                ]}>
                 <div class:list={[
  "universo-panel__texto",
  `universo-panel__texto--${recorrido.id}`,
]}>
  <p class="universo-panel__destacado subtitulo-cormorant">
    <strong>{recorrido.destacado}</strong>
  </p>

  <div class="universo-panel__cuerpo space-y-4 leading-relaxed text-white/72">
    {recorrido.contenido.map((parrafo) => (
      <p>{parrafo}</p>
    ))}
  </div>

  <div class="universo-panel__nav mt-8 flex gap-4 flex-wrap">
    <button class="volver-mapa" type="button" data-target="mapa">
      Volver arriba
    </button>
    {index < recorridos.length - 1 && (
      <button
        class="mapa-chip universo-panel__next"
        type="button"
        data-next={recorridos[index + 1].id}
      >
        Continuar
      </button>
    )}
  </div>
</div>

                 {recorrido.media?.length > 0 && (
  <aside class:list={[
    "universo-panel__media",
    recorrido.id === "exploracion" && "mt-7",
    recorrido.id === "simbolo" && "mt-7",
  ]}>
    {recorrido.media?.includes("image") && (
      <div class:list={[
        "panel-media-deep overflow-hidden rounded-[2rem] p-[1px] shadow-[0_14px_60px_rgba(0,0,0,0.28)]",
        recorrido.id === "simbolo" && "mx-auto max-w-2xl",
      ]}>
        <div class="relative rounded-[1.9rem] bg-[#0a0610]/96 p-4 backdrop-blur-2xl md:p-5">
          <div class:list={[
            "flex items-center justify-center rounded-[1.7rem] bg-[radial-gradient(circle_at_center,rgba(236,220,184,0.06),transparent_64%)] px-5",
            recorrido.id === "origen" && "min-h-[320px] md:min-h-[430px]",
            recorrido.id === "musica" && "min-h-[280px] md:min-h-[360px]",
            recorrido.id === "sonologia" && "min-h-[220px] md:min-h-[280px]",
            recorrido.id === "experiencias" && "min-h-[220px] md:min-h-[280px]",
            recorrido.id === "simbolo" && "min-h-[260px] md:min-h-[340px]",
          ]}>
            <div class="text-center">
              <p class="mb-2 text-[11px] uppercase tracking-[0.28em] text-[#ecdcb8]/56">
                Presencia visual
              </p>
              <p class="subtitulo-cormorant mx-auto max-w-xs text-sm leading-relaxed text-white/50">
                Este espacio puede recibir una imagen, símbolo, textura o pieza visual asociada a este tramo del recorrido.
              </p>
            </div>
          </div>
        </div>
      </div>
    )}

    {recorrido.media?.includes("video") && (
      <div class="subpanel-universo rounded-[1.8rem] px-5 py-5">
        <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
          Capa audiovisual
        </p>

        <h3 class="titulo-editorial mb-3 text-[1.35rem] leading-tight text-[#ecdcb8]">
          Presencia expandida
        </h3>

        <p class="subtitulo-cormorant text-sm leading-relaxed text-white/68">
          Este espacio puede recibir un video embebido, una pieza breve o un portal visual que prolongue la resonancia del bloque.
        </p>
      </div>
    )}

    {recorrido.media?.includes("note") && (
      <div class="subpanel-soft rounded-[1.8rem] px-5 py-5">
        <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
          Punto de apoyo
        </p>

        <h3 class="titulo-editorial mb-3 text-[1.2rem] leading-tight text-[#ecdcb8]">
          Capa conceptual
        </h3>

        <p class="subtitulo-cormorant text-sm leading-relaxed text-white/68">
          Este bloque puede alojar una frase, una imagen mínima o una textura más abstracta, sin romper la lectura central.
        </p>
      </div>
    )}
  </aside>
)}
                </div>
              </div>
            </div>
          </article>
        ))}
      </section>

  <script>
  const initUniverso = () => {
    const bloques = Array.from(document.querySelectorAll(".universo-panel"));
    const mapButtons = Array.from(document.querySelectorAll("[data-open]"));
    const volverButtons = Array.from(document.querySelectorAll('[data-target="mapa"]'));
    const continueButtons = Array.from(document.querySelectorAll("[data-next]"));
    const mapa = document.getElementById("mapa");

    if (!bloques.length) return;

    const scrollToWithOffset = (element, offset = 96) => {
  if (!element) return;
  const top = element.getBoundingClientRect().top + window.scrollY - offset;
  window.scrollTo({ top, behavior: "smooth" });
};

const scrollToBloqueHeader = (bloque, offset = 96) => {
  if (!bloque) return;
  const header = bloque.querySelector(".universo-panel__toggle");
  scrollToWithOffset(header || bloque, offset);
};

const getTransitionMs = (element) => {
  if (!element) return 0;

  const styles = window.getComputedStyle(element);
  const durations = styles.transitionDuration.split(",").map((value) => {
    const v = value.trim();
    return v.endsWith("ms") ? parseFloat(v) : parseFloat(v) * 1000;
  });

  const delays = styles.transitionDelay.split(",").map((value) => {
    const v = value.trim();
    return v.endsWith("ms") ? parseFloat(v) : parseFloat(v) * 1000;
  });

  const total = durations.map((duration, index) => {
    return duration + (delays[index] || 0);
  });

  return Math.max(...total, 0);
};

const scrollToBloqueHeaderAfterTransition = (bloque, offset = 96) => {
  const { content } = getParts(bloque);
  const wait = getTransitionMs(content) + 28;

  window.setTimeout(() => {
    scrollToBloqueHeader(bloque, offset);
  }, wait);
};

    const getParts = (bloque) => {
      if (!bloque) return {};
      return {
        button: bloque.querySelector(".universo-panel__toggle"),
        content: bloque.querySelector(".universo-panel__contenido"),
        icon: bloque.querySelector(".universo-panel__icon"),
      };
    };

    const closeBloque = (bloque) => {
      const { button, content, icon } = getParts(bloque);
      if (!button || !content || !icon) return;

      button.setAttribute("aria-expanded", "false");
      bloque.classList.remove("is-open");
      content.style.maxHeight = "0px";
      icon.style.transform = "rotate(0deg)";
    };

    const openBloque = (bloque) => {
      const { button, content, icon } = getParts(bloque);
      if (!button || !content || !icon) return;

      bloques.forEach((item) => {
        if (item !== bloque) closeBloque(item);
      });

      button.setAttribute("aria-expanded", "true");
      bloque.classList.add("is-open");
      content.style.maxHeight = `${content.scrollHeight}px`;
      icon.style.transform = "rotate(45deg)";
    };

    const toggleBloque = (bloque) => {
  const { button } = getParts(bloque);
  if (!button) return;

  const isExpanded = button.getAttribute("aria-expanded") === "true";
  if (isExpanded) {
    closeBloque(bloque);
  } else {
    openBloque(bloque);
    scrollToBloqueHeaderAfterTransition(bloque, 96);
  }
};

    bloques.forEach((bloque) => {
      const { button, content } = getParts(bloque);
      if (!button || !content) return;

      content.style.maxHeight = "0px";
      button.setAttribute("aria-expanded", "false");

      button.addEventListener("click", () => {
        toggleBloque(bloque);
      });
    });

    mapButtons.forEach((btn) => {
  btn.addEventListener("click", () => {
    const targetId = btn.getAttribute("data-open");
    if (!targetId) return;

    const target = document.querySelector(`[data-recorrido="${targetId}"]`);
    if (!target) return;

    openBloque(target);
    scrollToBloqueHeaderAfterTransition(target, 96);
  });
});

    continueButtons.forEach((btn) => {
  btn.addEventListener("click", () => {
    const nextId = btn.getAttribute("data-next");
    if (!nextId) return;

    const current = btn.closest("[data-recorrido]");
    const target = document.querySelector(`[data-recorrido="${nextId}"]`);
    if (!target) return;

    btn.blur();

    if (current) closeBloque(current);
    openBloque(target);
    scrollToBloqueHeaderAfterTransition(target, 96);
  });
});

    volverButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        bloques.forEach(closeBloque);
        if (mapa) scrollToWithOffset(mapa, 96);
      });
    });

    window.addEventListener("resize", () => {
      const abierto = document.querySelector(".universo-panel.is-open");
      if (!abierto) return;

      const { content } = getParts(abierto);
      if (!content) return;

      content.style.maxHeight = `${content.scrollHeight}px`;
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initUniverso);
  } else {
    initUniverso();
  }
</script>

  <style>
    .titulo-cinzel {
  font-family: "Cinzel", "Cinzel Decorative", serif;
  font-weight: 400;
  letter-spacing: 0.02em;
  text-transform: none;
}

.titulo-editorial,
.portal-piece__title,
.portal-card__title,
.universo-panel__toggle h2,
.subpanel-universo h3,
.subpanel-soft h3 {
  font-family: "Cormorant Garamond", serif;
  font-weight: 500;
  letter-spacing: 0.01em;
  text-transform: none;
}

.subtitulo-cormorant,
.portal-piece__hint,
.portal-card__hint,
.universo-panel__toggle > div > p,
.universo-panel__texto > p,
.subpanel-universo p:not(:first-child),
.subpanel-soft p:not(:first-child),
.volver-mapa {
  font-family: "Cormorant Garamond", serif;
}

.mapa-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(236, 220, 184, 0.35);
  padding: 0.7rem 1.1rem;
  color: #ecdcb8;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.04);
  transition: 0.3s ease;
  border-radius: 999px;
  font-size: 0.92rem;
  letter-spacing: 0.03em;
}

.mapa-chip:hover {
  transform: translateY(-1px);
  border-color: rgba(236, 220, 184, 0.55);
  background: rgba(236, 220, 184, 0.1);
}

.portal-shell,
.universo-panel {
  position: relative;
}

.portal-shell::before,
.universo-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 2.2rem;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.06),
    rgba(255, 255, 255, 0.01)
  );
  pointer-events: none;
  opacity: 0.5;
}

/* =========================
   PORTAL WRAPPER
========================= */

.portal-wrapper {
  position: relative;
}

.portal-desktop {
  position: relative;
  height: 26.8rem;
}

.portal-mobile {
  display: none;
}

.portal-piece {
  position: absolute;
  border: none;
  background: transparent;
  padding: 0;
  cursor: pointer;
  isolation: isolate;
}

.portal-piece__bg {
  position: absolute;
  inset: 0;
  display: block;
  background:
    radial-gradient(circle at top left, rgba(236, 220, 184, 0.08), transparent 42%),
    linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  box-shadow:
    0 18px 40px rgba(0,0,0,0.24),
    inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition:
    transform 240ms ease,
    box-shadow 240ms ease,
    filter 240ms ease;
  z-index: 0;
}

.portal-piece:hover .portal-piece__bg {
  transform: translateY(-2px) scale(1.012);
  box-shadow:
    0 22px 46px rgba(0,0,0,0.3),
    inset 0 1px 0 rgba(255,255,255,0.07);
  filter: brightness(1.04);
}

.portal-piece__content {
  position: absolute;
  inset: 0;
  z-index: 1;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 0.48rem;
  padding: 1rem 1.05rem 0.96rem;
}

.portal-piece__label {
  font-size: 11px;
  line-height: 1;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(236, 220, 184, 0.55);
  font-weight: 600;
  text-shadow: 0 0 14px rgba(236, 220, 184, 0.08);
}

.portal-piece__title {
  font-size: clamp(1.2rem, 1.34vw, 1.52rem);
  line-height: 0.92;
  color: #f0dfb8;
  font-weight: 500;
  text-wrap: balance;
  align-self: center;
  letter-spacing: 0.01em;
  text-shadow: 0 0 18px rgba(240, 223, 184, 0.08);
}

.portal-piece__hint {
  font-size: 0.9rem;
  line-height: 1.08;
  color: rgba(255,255,255,0.74);
  font-weight: 500;
  font-style: italic;
}

/* =========================
   DESKTOP — BOTONERA
========================= */

.portal-piece--1,
.portal-piece--2,
.portal-piece--3,
.portal-piece--4,
.portal-piece--5,
.portal-piece--6 {
  height: 49.35%;
}

.portal-piece--1 {
  top: 0;
  left: 0;
  width: 32.6%;
  z-index: 1;
}

.portal-piece--2 {
  top: 0;
  left: 30%;
  width: 40%;
  z-index: 2;
}

.portal-piece--3 {
  top: 0;
  right: 0;
  width: 32.6%;
  z-index: 1;
}

.portal-piece--4 {
  bottom: 0;
  left: 0;
  width: 32.6%;
  z-index: 1;
}

.portal-piece--5 {
  bottom: 0;
  left: 30%;
  width: 40%;
  z-index: 2;
}

.portal-piece--6 {
  bottom: 0;
  right: 0;
  width: 32.6%;
  z-index: 1;
}

/* =========================
   DESKTOP — FORMAS
========================= */

.portal-piece--1 .portal-piece__bg {
  clip-path: polygon(0 0, 100% 0, 90% 100%, 0 100%);
  border-radius: 1.55rem 1rem 0.9rem 1.55rem;
}

.portal-piece--2 .portal-piece__bg {
  clip-path: polygon(8% 0, 92% 0, 100% 100%, 0 100%);
  border-radius: 0;
}

.portal-piece--3 .portal-piece__bg {
  clip-path: polygon(0 0, 100% 0, 100% 100%, 10% 100%);
  border-radius: 1rem 1.55rem 1.55rem 0.9rem;
}

.portal-piece--4 .portal-piece__bg {
  clip-path: polygon(0 0, 90% 0, 100% 100%, 0 100%);
  border-radius: 1.55rem 0.9rem 1rem 1.55rem;
}

.portal-piece--5 .portal-piece__bg {
  clip-path: polygon(0 0, 100% 0, 92% 100%, 8% 100%);
  border-radius: 0;
}

.portal-piece--6 .portal-piece__bg {
  clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%);
  border-radius: 0.9rem 1.55rem 1.55rem 1rem;
}

.portal-piece--2 .portal-piece__bg,
.portal-piece--5 .portal-piece__bg {
  background:
    radial-gradient(circle at center, rgba(236, 220, 184, 0.11), transparent 54%),
    linear-gradient(180deg, rgba(255,255,255,0.058), rgba(255,255,255,0.02));
}

.portal-piece--3 .portal-piece__bg,
.portal-piece--6 .portal-piece__bg {
  background:
    radial-gradient(circle at top right, rgba(148,111,214,0.14), transparent 52%),
    linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
}

[data-recorrido="exploracion"] .universo-panel__toggle,
[data-recorrido="simbolo"] .universo-panel__toggle {
  justify-content: flex-start;
  align-items: flex-start;
}

[data-recorrido="exploracion"] .universo-panel__toggle .universo-head,
[data-recorrido="simbolo"] .universo-panel__toggle .universo-head {
  flex: 1 1 auto;
  max-width: 980px;
  text-align: left;
}

