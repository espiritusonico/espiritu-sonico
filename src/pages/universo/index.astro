---
import Layout from "../../layouts/Layout.astro";
import "../../styles/productos-slug.css";
import { recorridos } from "../../data/universoRecorridos";
---

<Layout title="Universo Espíritu Sónico">
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.025),transparent_45%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <!-- HEADER -->
      <header class="mb-20 text-center">
         <h1 class="titulo-cinzel mx-auto mb-6 max-w-4xl text-4xl leading-tight text-[#ecdcb8] md:text-6xl">
          Universo Espíritu Sónico
        </h1>

        <p class="es-page-subtitle mx-auto max-w-[19rem] md:max-w-3xl">
          Sonido, símbolo, conciencia y una manera muy concreta de transformar intuición en experiencia.
        </p>

        <div class="mx-auto mt-10 h-px w-32 bg-gradient-to-r from-transparent via-[#ecdcb8]/60 to-transparent"></div>
      </header>

      <!-- PORTAL -->
      <section id="mapa" class="mx-auto mb-16 max-w-6xl">
  <div class="portal-shell card-ritual rounded-[2.2rem]">
    <div class="relative rounded-[2.1rem] bg-transparent px-6 py-7 md:px-8 md:py-8">
      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
        <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.06] blur-3xl"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.02),transparent_50%)]"></div>
      </div>

      <div class="relative z-10">
        <div class="card-viaje-destacado mx-auto mb-8 max-w-3xl rounded-[1.9rem] px-6 py-5 text-center">
          <p class="eyebrow-ritual mb-3">Ingreso</p>

          <h2 class="titulo-cinzel mb-3 text-[1.9rem] leading-tight text-[#ecdcb8] md:text-[2.35rem]">
            Elegí un portal
          </h2>

          <p class="subtitulo-cormorant text-[14px] leading-relaxed text-white/70 md:text-[15px]">
            Cada acceso abre una dimensión distinta del universo.
          </p>
        </div>

        <div class="portal-botonera-shell mx-auto">
          <div class="portal-wrapper">
            <!-- DESKTOP -->
  <div class="portal-desktop">
  {recorridos.map((recorrido, index) => {
    const slot = index + 1;

    const desktopShapeD = {
      1: "M 10 0 H 97 Q 100 0 99.4 3 L 90.6 96.5 Q 90.1 100 86.5 100 H 10 Q 0 100 0 90 V 10 Q 0 0 10 0 Z",
      2: "M 11 0 H 89 Q 92 0 92.6 3.2 L 99.4 96.5 Q 100 100 96.4 100 H 3.6 Q 0 100 0.6 96.5 L 7.4 3.2 Q 8 0 11 0 Z",
      3: "M 3 0 H 90 Q 100 0 100 10 V 90 Q 100 100 90 100 H 13.5 Q 9.9 100 9.4 96.5 L 0.6 3 Q 0 0 3 0 Z",
      4: "M 10 0 H 86.5 Q 90.1 0 90.6 3.5 L 99.4 97 Q 100 100 97 100 H 10 Q 0 100 0 90 V 10 Q 0 0 10 0 Z",
      5: "M 3.6 0 H 96.4 Q 100 0 99.4 3.5 L 92.6 96.8 Q 92 100 89 100 H 11 Q 8 100 7.4 96.8 L 0.6 3.5 Q 0 0 3.6 0 Z",
      6: "M 13.5 0 H 90 Q 100 0 100 10 V 90 Q 100 100 90 100 H 3 Q 0 100 0.6 97 L 9.4 3.5 Q 9.9 0 13.5 0 Z",
    }[slot];

    return (
      <button
        type="button"
        class={`portal-piece portal-piece--${slot}`}
        data-open={recorrido.id}
      >
        <svg class="portal-piece__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id={`portalDeskMaterial-${index}`} x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgba(236, 220, 184, 0.032)" />
              <stop offset="100%" stop-color="rgba(236, 220, 184, 0.012)" />
            </linearGradient>

            <radialGradient id={`portalDeskHalo-${index}`} cx="50%" cy="0%" r="70%">
              <stop offset="0%" stop-color="rgba(236, 220, 184, 0.055)" />
              <stop offset="100%" stop-color="rgba(236, 220, 184, 0)" />
            </radialGradient>
          </defs>

          <path class="portal-piece__shape-base" d={desktopShapeD} />
          <path class="portal-piece__shape-material" d={desktopShapeD} fill={`url(#portalDeskMaterial-${index})`} />
          <path class="portal-piece__shape-halo" d={desktopShapeD} fill={`url(#portalDeskHalo-${index})`} />
          <path class="portal-piece__shape-border" d={desktopShapeD} />
        </svg>

        <div class="portal-piece__content">
          <p class="portal-piece__label es-label">{recorrido.portalLabel}</p>
<h3 class="portal-piece__title titulo-editorial es-portal-title">
{recorrido.id === "exploracion" ? (
  <>
    <span class="portal-title-line">Exploración&nbsp;de</span>
    <span class="portal-title-line">la&nbsp;conciencia</span>
  </>
) : (
  recorrido.titulo
)}
</h3>
<p class="portal-piece__hint es-portal-hint" set:html={recorrido.portalHint}></p>
        </div>
      </button>
    );
  })}
</div>

<!-- MOBILE / TABLET -->
<div class="portal-mobile">
  {recorridos.map((recorrido, index) => {
    const esIzquierda = index % 2 === 0;

const shapeD = esIzquierda
  ? "M 9 0 H 97 Q 100 0 99.4 3 L 90.6 96.5 Q 90.1 100 86.5 100 H 9 Q 0 100 0 91 V 9 Q 0 0 9 0 Z"
  : "M 13.5 0 H 91 Q 100 0 100 9 V 91 Q 100 100 91 100 H 3 Q 0 100 0.6 97 L 9.4 3.5 Q 9.9 0 13.5 0 Z";

    return (
      <button
        type="button"
        class={`portal-card portal-card--slot-${index + 1}`}
        data-open={recorrido.id}
      >
        <svg class="portal-card__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
  <defs>
    <linearGradient id={`portalMaterial-${index}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgba(236, 220, 184, 0.032)" />
      <stop offset="100%" stop-color="rgba(236, 220, 184, 0.012)" />
    </linearGradient>

    <radialGradient id={`portalHalo-${index}`} cx="50%" cy="0%" r="70%">
      <stop offset="0%" stop-color="rgba(236, 220, 184, 0.055)" />
      <stop offset="100%" stop-color="rgba(236, 220, 184, 0)" />
    </radialGradient>
  </defs>

  <path class="portal-card__shape-base" d={shapeD} />
  <path class="portal-card__shape-material" d={shapeD} fill={`url(#portalMaterial-${index})`} />
  <path class="portal-card__shape-halo" d={shapeD} fill={`url(#portalHalo-${index})`} />
  <path class="portal-card__shape-border" d={shapeD} />
</svg>

        <div class="portal-card__content">
          <p class="portal-card__label es-label">{recorrido.portalLabel}</p>
<h3 class="portal-card__title titulo-editorial es-portal-title-mobile">
{recorrido.id === "exploracion" ? (
  <>
    <span class="portal-title-line">Exploración&nbsp;de</span>
    <span class="portal-title-line">la&nbsp;conciencia</span>
  </>
) : (
  recorrido.titulo
)}
</h3>
<p class="portal-card__hint es-portal-hint-mobile" set:html={recorrido.portalHint}></p>
        </div>
      </button>
    );
  })}
</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

      <!-- BLOQUES -->
      <section class="mx-auto max-w-[68rem] space-y-8">
        {recorridos.map((recorrido, index) => (
          <article
            class:list={[
  "universo-panel mx-auto w-full card-ritual hidden rounded-[2.2rem] opacity-0 translate-y-6 transition-all duration-500 ease-out",
  recorrido.id === "sonologia" && "universo-panel--principal",
  recorrido.id === "simbolo" && "universo-panel--compacto",
]}
            data-recorrido={recorrido.id}
          >
           <div class="relative rounded-[2.1rem] bg-transparent">
              <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
                <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.04] blur-3xl"></div>
                <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.05] blur-3xl"></div>
              </div>

              <button
                class="universo-panel__toggle relative z-10 flex w-full items-start justify-between gap-5 px-6 py-7 text-left md:px-8 md:py-8"
                type="button"
                aria-expanded="false"
                aria-controls={`contenido-${recorrido.id}`}
              >
                <div class="min-w-0 universo-head">
                  <p class="mb-3 es-eyebrow">
  {recorrido.portalLabel}
</p>

                  <h2 class="titulo-editorial es-title">
  {recorrido.titulo}
</h2>

                  <p class="es-reading-summary max-w-4xl">
  {recorrido.resumen}
</p>
                </div>

                <span class="universo-panel__icon mt-1 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-xl text-[#ecdcb8] transition duration-300">
                  +
                </span>
              </button>

              <div
                id={`contenido-${recorrido.id}`}
                class="universo-panel__contenido"
              >
                <div class:list={[
                  "relative z-10 gap-7 px-6 pb-7 md:px-8 md:pb-8",
                  recorrido.id === "origen" && "grid lg:grid-cols-[1.1fr_0.9fr]",
                  recorrido.id === "musica" && "grid lg:grid-cols-[0.9fr_1.1fr]",
                  recorrido.id === "exploracion" && "mx-auto max-w-4xl",
                  recorrido.id === "sonologia" && "grid lg:grid-cols-[1.05fr_0.95fr] lg:items-center",
                  recorrido.id === "experiencias" && "grid lg:grid-cols-[0.92fr_1.08fr]",
                  recorrido.id === "simbolo" && "mx-auto max-w-6xl",
                ]}>
                 <div class:list={[
  "universo-panel__texto es-reading-card card-viaje-destacado rounded-[1.9rem] p-5 md:p-6",
  `universo-panel__texto--${recorrido.id}`,
]}>
  <p class="universo-panel__destacado es-reading-highlight">
  <strong>{recorrido.destacado}</strong>
</p>

<div class="universo-panel__cuerpo es-reading es-reading-stack">  {recorrido.contenido.map((parrafo) => (
    <p>{parrafo}</p>
  ))}
</div>

  <div class="universo-panel__nav mt-8 flex gap-4 flex-wrap">
    <button class="volver-mapa" type="button" data-target="mapa">
      Volver arriba
    </button>
    {index < recorridos.length - 1 && (
      <button
        class="mapa-chip universo-panel__next"
        type="button"
        data-next={recorridos[index + 1].id}
      >
        Continuar
      </button>
    )}
  </div>
</div>

                 {recorrido.media?.length > 0 && (
  <aside class:list={[
    "universo-panel__media",
    recorrido.id === "exploracion" && "mt-7",
    recorrido.id === "simbolo" && "mt-7",
  ]}>
    {recorrido.media?.includes("image") && (
      <div class:list={[
  "subpanel-soft rounded-[2rem] p-4 md:p-5",
  recorrido.id === "simbolo" && "mx-auto max-w-2xl",
]}>
  <div class:list={[
    "flex items-center justify-center rounded-[1.7rem] bg-[radial-gradient(circle_at_center,rgba(236,220,184,0.06),transparent_64%)] px-5",
    recorrido.id === "origen" && "min-h-[320px] md:min-h-[430px]",
    recorrido.id === "musica" && "min-h-[280px] md:min-h-[360px]",
    recorrido.id === "sonologia" && "min-h-[220px] md:min-h-[280px]",
    recorrido.id === "experiencias" && "min-h-[220px] md:min-h-[280px]",
    recorrido.id === "simbolo" && "min-h-[260px] md:min-h-[340px]",
  ]}>
    <div class="text-center">
      <p class="mb-2 text-[11px] uppercase tracking-[0.28em] text-[#ecdcb8]/56">
        Presencia visual
      </p>
      <p class="es-sidecopy mx-auto max-w-xs">
        Este espacio puede recibir una imagen, símbolo, textura o pieza visual asociada a este tramo del recorrido.
      </p>
    </div>
  </div>
</div>
</div>
    )}

    {recorrido.media?.includes("video") && (
     <div class="subpanel-viaje rounded-[1.8rem] px-5 py-5">
        <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
          Capa audiovisual
        </p>

        <h3 class="titulo-editorial mb-3 text-[1.35rem] leading-tight text-[#ecdcb8]">
          Presencia expandida
        </h3>

        <p class="es-sidecopy">
  Este espacio puede recibir un video embebido, una pieza breve o un portal visual que prolongue la resonancia del bloque.
</p>
      </div>
    )}

    {recorrido.media?.includes("note") && (
      <div class="subpanel-soft rounded-[1.8rem] px-5 py-5">
        <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
          Punto de apoyo
        </p>

        <h3 class="titulo-editorial mb-3 text-[1.2rem] leading-tight text-[#ecdcb8]">
          Capa conceptual
        </h3>

        <p class="es-sidecopy">
  Este bloque puede alojar una frase, una imagen mínima o una textura más abstracta, sin romper la lectura central.
</p>
      </div>
    )}
  </aside>
)}
                </div>
              </div>
            </div>
          </article>
        ))}
      </section>

<script>
  const initUniverso = () => {
    const bloques = Array.from(document.querySelectorAll(".universo-panel"));
    const mapButtons = Array.from(document.querySelectorAll("[data-open]"));
    const volverButtons = Array.from(document.querySelectorAll('[data-target="mapa"]'));
    const continueButtons = Array.from(document.querySelectorAll("[data-next]"));
    const mapa = document.getElementById("mapa");

    if (!bloques.length) return;

const playPress = (button, callback) => {
  if (!button) {
    callback();
    return;
  }

  button.classList.add("is-pressing");

  window.setTimeout(() => {
    button.classList.remove("is-pressing");
    callback();
  }, 135);
};

    const scrollElementIntoView = (element, offset = 96) => {
      if (!element) return;

      const top = element.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: "smooth" });
    };

    const scrollToBloqueHeader = (bloque, offset = 96) => {
      if (!bloque) return;
      const header = bloque.querySelector(".universo-panel__toggle");
      scrollElementIntoView(header || bloque, offset);
    };

const revealBloqueCollapsed = (bloque) => {
  const { button, content, icon } = getParts(bloque);
  if (!button || !content || !icon) return;

  bloques.forEach((item) => {
    if (item !== bloque) closeBloque(item);
  });

  bloque.classList.remove("hidden", "opacity-0", "translate-y-6");
  bloque.classList.add("opacity-100", "translate-y-0");

  button.setAttribute("aria-expanded", "false");
  bloque.classList.remove("is-open");
  content.style.maxHeight = "0px";
  icon.style.transform = "rotate(0deg)";
};

const navigateToBloque = (bloque) => {
  if (!bloque) return;

  revealBloqueCollapsed(bloque);
  scrollToBloqueHeader(bloque, 96);

  window.requestAnimationFrame(() => {
    openBloque(bloque);
  });
};

    const getParts = (bloque) => {
      if (!bloque) return {};
      return {
        button: bloque.querySelector(".universo-panel__toggle"),
        content: bloque.querySelector(".universo-panel__contenido"),
        icon: bloque.querySelector(".universo-panel__icon"),
      };
    };

    const closeBloque = (bloque) => {
      const { button, content, icon } = getParts(bloque);
      if (!button || !content || !icon) return;

      button.setAttribute("aria-expanded", "false");
      bloque.classList.remove("is-open");
      content.style.maxHeight = "0px";
      icon.style.transform = "rotate(0deg)";
    };

    const openBloque = (bloque) => {
  const { button, content, icon } = getParts(bloque);
  if (!button || !content || !icon) return;

  bloques.forEach((item) => {
    if (item !== bloque) closeBloque(item);
  });

  bloque.classList.remove("hidden", "opacity-0", "translate-y-6");
  bloque.classList.add("opacity-100", "translate-y-0");

  button.setAttribute("aria-expanded", "true");
  bloque.classList.add("is-open");
  content.style.maxHeight = `${content.scrollHeight}px`;
  icon.style.transform = "rotate(45deg)";
};

    const toggleBloque = (bloque) => {
      const { button } = getParts(bloque);
      if (!button) return;

      const isExpanded = button.getAttribute("aria-expanded") === "true";
      if (isExpanded) {
        closeBloque(bloque);
      } else {
        openBloque(bloque);
        scrollToBloqueHeader(bloque, 96);
      }
    };

    bloques.forEach((bloque) => {
      const { button, content } = getParts(bloque);
      if (!button || !content) return;

      content.style.maxHeight = "0px";
      button.setAttribute("aria-expanded", "false");

      button.addEventListener("click", () => {
        toggleBloque(bloque);
      });
    });

mapButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-open");
      if (!targetId) return;

    const target = document.querySelector(`[data-recorrido="${targetId}"]`);
    if (!target) return;

    btn.blur();

    playPress(btn, () => {
      navigateToBloque(target);
    });
  });
});

    continueButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const nextId = btn.getAttribute("data-next");
        if (!nextId) return;

        const current = btn.closest("[data-recorrido]");
        const target = document.querySelector(`[data-recorrido="${nextId}"]`);
        if (!target) return;

        btn.blur();

        if (current) closeBloque(current);
        navigateToBloque(target);
      });
    });

    volverButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const current = btn.closest("[data-recorrido]");
        if (current) closeBloque(current);

        if (mapa) scrollElementIntoView(mapa);
      });
    });

    window.addEventListener("resize", () => {
      const abierto = document.querySelector(".universo-panel.is-open");
      if (!abierto) return;

      const { content } = getParts(abierto);
      if (!content) return;

      content.style.maxHeight = `${content.scrollHeight}px`;
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initUniverso);
  } else {
    initUniverso();
  }
</script>



  <style>
    .titulo-cinzel {
  font-family: "Cinzel", "Cinzel Decorative", serif;
  font-weight: 400;
  letter-spacing: 0.02em;
  text-transform: none;
}

.titulo-editorial,
.portal-piece__title,
.portal-card__title,
.universo-panel__toggle h2,
.subpanel-universo h3,
.subpanel-soft h3 {
  font-family: "Cormorant Garamond", serif;
  font-weight: 500;
  letter-spacing: 0.01em;
  text-transform: none;
}

.subtitulo-cormorant,
.portal-piece__hint,
.portal-card__hint,
.universo-panel__toggle > div > p,
.subpanel-universo p:not(:first-child),
.subpanel-soft p:not(:first-child),
.volver-mapa {
  font-family: "Cormorant Garamond", serif;
}

.universo-panel__toggle {
  scroll-margin-top: 96px;
}

#mapa {
  scroll-margin-top: 96px;
}

.mapa-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(236, 220, 184, 0.35);
  padding: 0.7rem 1.1rem;
  color: #ecdcb8;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.04);
  transition: 0.3s ease;
  border-radius: 999px;
  font-size: 0.92rem;
  letter-spacing: 0.03em;
}

.mapa-chip:hover {
  transform: translateY(-1px);
  border-color: rgba(236, 220, 184, 0.55);
  background: rgba(236, 220, 184, 0.1);
}

.portal-shell,
.universo-panel {
  position: relative;
}

.portal-shell::before,
.universo-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 2.2rem;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.06),
    rgba(255, 255, 255, 0.01)
  );
  pointer-events: none;
  opacity: 0.5;
}

/* =========================
   PORTAL WRAPPER
========================= */

.portal-wrapper {
  position: relative;
}

.portal-desktop {
  position: relative;
  height: 26.8rem;
}

.portal-mobile {
  display: none;
}

.portal-piece {
  position: absolute;
  border: none;
  background: transparent;
  padding: 0;
  cursor: pointer;
  isolation: isolate;
}

.portal-piece__bg {
  position: absolute;
  inset: 0;
  display: block;
  background:
    linear-gradient(180deg, rgba(236, 220, 184, 0.045) 0%, rgba(236, 220, 184, 0.015) 100%),
    rgba(18, 10, 24, 0.82);
  border: 1px solid rgba(236, 220, 184, 0.08);
  box-shadow:
    inset 0 1px 0 rgba(236, 220, 184, 0.03),
    0 10px 60px rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  transition:
    transform 240ms ease,
    box-shadow 240ms ease,
    filter 240ms ease,
    border-color 240ms ease,
    background 240ms ease;
  z-index: 0;
}

.portal-piece:hover .portal-piece__bg {
  transform: translateY(-2px) scale(1.012);
  border-color: rgba(236, 220, 184, 0.22);
  box-shadow:
    inset 0 1px 0 rgba(236, 220, 184, 0.04),
    0 14px 70px rgba(0, 0, 0, 0.24);
  filter: brightness(1.02);
}

