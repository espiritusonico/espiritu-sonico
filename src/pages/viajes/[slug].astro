---
import Layout from "../../layouts/Layout.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import { getViajes } from "../../lib/api";
import { mapViajeDetail } from "../../lib/mappers";
import { getViajeVisualFallback } from "../../lib/viajes-contenido";

export async function getStaticPaths() {
  try {
    const data = await getViajes();

    const viajes = Array.isArray(data)
  ? data
      .map(mapViajeDetail)
      .filter((viaje) => viaje.publicado)
  : [];

    return viajes.map((viaje) => ({
      params: { slug: viaje.slug },
      props: { viaje },
    }));
  } catch (error) {
    console.warn("No se pudieron obtener los viajes para getStaticPaths:", error);
    return [];
  }
}

const { viaje: viajeRaw } = Astro.props;
const viaje = mapViajeDetail(viajeRaw);

const visual = getViajeVisualFallback(viaje);
---

<Layout title={viaje.titulo}>
  <section class="relative min-h-screen overflow-hidden px-6 pb-24 pt-20 text-white">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-[34rem] w-[34rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.04] blur-3xl"></div>
      <div class="absolute -left-24 top-1/3 h-80 w-80 rounded-full bg-violet-400/[0.07] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-96 w-96 rounded-full bg-fuchsia-300/[0.05] blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.03),transparent_45%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="mb-12 text-center">
        <p class="mb-5 text-xs uppercase tracking-[0.45em] text-[#ecdcb8]/55">
          Espíritu Sónico · Viaje Sonoro
        </p>

        <h1 class="mx-auto mb-4 max-w-4xl text-4xl font-light leading-tight text-[#ecdcb8] md:text-6xl">
          {viaje.titulo}
        </h1>

        <p class="mb-6 text-xs uppercase tracking-[0.28em] text-white/45 md:text-sm">
          {visual.subtitulo}
        </p>

        <p class="mx-auto max-w-3xl text-base leading-relaxed text-white/72 md:text-lg">
          {visual.frase}
        </p>

        <div class="mx-auto mt-10 h-px w-40 bg-gradient-to-r from-transparent via-[#ecdcb8]/60 to-transparent"></div>
      </div>

      <div class="space-y-8">
  <AudioPlayer
    src={viaje.audioUrl}
    title={viaje.titulo}
    subtitle={visual.subtitulo}
    duration={viaje.duracion}
  />

  <article class="overflow-hidden rounded-[2.2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.025))] p-[1px] shadow-[0_10px_60px_rgba(0,0,0,0.22)]">
    <div class="relative rounded-[2.1rem] bg-[#120a18]/80 px-7 py-8 backdrop-blur-2xl md:px-10 md:py-10">
      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
        <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.06] blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-36 w-36 rounded-full bg-violet-300/[0.07] blur-3xl"></div>
      </div>

      <div class="relative z-10">
        <p class="mb-3 text-[11px] uppercase tracking-[0.32em] text-white/35">
          Propósito del viaje
        </p>
        <p class="text-[15px] leading-relaxed text-white/75 md:text-[17px]">
          {visual.proposito}
        </p>
      </div>
    </div>
  </article>

  <article class="overflow-hidden rounded-[2.2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02))] p-[1px]">
    <div class="relative rounded-[2.1rem] bg-[#140d1b]/75 px-7 py-8 backdrop-blur-2xl md:px-10 md:py-10">
      <div class="relative z-10">
        <h2 class="mb-4 text-2xl font-light text-[#ecdcb8] md:text-3xl">
          Cómo está construido
        </h2>
        <p class="text-[15px] leading-relaxed text-white/72 md:text-base">
          {visual.construccion}
        </p>
      </div>
    </div>
  </article>

  <article class="overflow-hidden rounded-[2.2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.02))] p-[1px]">
    <div class="relative rounded-[2.1rem] bg-[#140d1b]/75 px-7 py-8 backdrop-blur-2xl md:px-10 md:py-10">
      <div class="relative z-10">
        <h2 class="mb-4 text-2xl font-light text-[#ecdcb8] md:text-3xl">
          El trabajo detrás
        </h2>
        <p class="text-[15px] leading-relaxed text-white/72 md:text-base">
          {visual.detras}
        </p>
      </div>
    </div>
  </article>

  <div class="grid gap-8 lg:grid-cols-2">
  <article class="relative rounded-[2.2rem] px-6 py-7 md:px-8 md:py-8 border border-white/8 bg-[linear-gradient(180deg,rgba(255,255,255,0.05)_0%,rgba(255,255,255,0.02)_100%),rgba(20,13,27,0.78)] shadow-[inset_0_1px_0_rgba(255,255,255,0.02),0_10px_60px_rgba(0,0,0,0.18)] backdrop-blur-[18px]">
    <h2 class="mb-5 text-2xl font-light text-[#ecdcb8]">
      Recomendaciones de uso
    </h2>

    <div class="space-y-3">
      {visual.recomendaciones.map((item) => (
        <div class="rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-4 text-sm leading-relaxed text-white/70">
          {item}
        </div>
      ))}
    </div>
  </article>

  <article class="relative rounded-[2.2rem] px-7 py-8 md:px-10 md:py-10 border border-white/8 bg-[linear-gradient(180deg,rgba(255,255,255,0.05)_0%,rgba(255,255,255,0.02)_100%),rgba(20,13,27,0.78)] shadow-[inset_0_1px_0_rgba(255,255,255,0.02),0_10px_60px_rgba(0,0,0,0.18)] backdrop-blur-[18px]">
    <div class="relative z-10">
      <h2 class="mb-5 text-2xl font-light text-[#ecdcb8] md:text-3xl">
        Qué puede mover esta escucha
      </h2>

      <div class="grid gap-3">
        {visual.durante.map((item) => (
          <div class="rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-4 text-sm leading-relaxed text-white/70">
            {item}
          </div>
        ))}
      </div>
    </div>
  </article>
</div>

  <article class="overflow-hidden rounded-[2.2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.015))] p-[1px]">
    <div class="relative rounded-[2.1rem] bg-[#120a18]/78 px-6 py-7 backdrop-blur-2xl md:px-8 md:py-8">
      <p class="mb-3 text-[11px] uppercase tracking-[0.32em] text-white/35">
        Sonología Ritual
      </p>

      <h2 class="mb-4 text-2xl font-light text-[#ecdcb8]">
  Sonología Ritual
</h2>

<p class="text-sm leading-relaxed text-white/70">
  {visual.sonologia}
</p>
    </div>
  </article>

  <div class="flex justify-center pt-2">
    <a
      href="/viajes"
      class="inline-flex items-center justify-center rounded-full border border-white/10 px-5 py-2.5 text-sm tracking-[0.08em] text-white/70 transition duration-300 hover:border-white/25 hover:bg-white/5"
    >
      Volver a viajes
    </a>
  </div>
</div>

  </section>
</Layout>