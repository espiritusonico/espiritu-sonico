---
import Layout from "../../layouts/Layout.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import "../../styles/productos-slug.css";
import { getViajes } from "../../lib/api";
import { mapViajeDetail } from "../../lib/mappers";
import { getViajeVisualFallback } from "../../lib/viajes-contenido";

export async function getStaticPaths() {
  try {
    const data = await getViajes();

    const viajes = Array.isArray(data)
      ? data.map(mapViajeDetail).filter((viaje) => viaje.publicado)
      : [];

    return viajes.map((viaje) => ({
      params: { slug: viaje.slug },
      props: { viaje },
    }));
  } catch (error) {
    console.warn("No se pudieron obtener los viajes para getStaticPaths:", error);
    return [];
  }
}

const { viaje: viajeRaw } = Astro.props;
const viaje = mapViajeDetail(viajeRaw);
const visual = getViajeVisualFallback(viaje);
---

<Layout title={viaje.titulo}>
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.025),transparent_45%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <header class="es-page-header mb-12">
        <h1 class="es-page-title mx-auto mb-4 max-w-4xl text-4xl md:text-6xl">
          {viaje.titulo}
        </h1>

        <p class="es-eyebrow-soft mb-6 md:text-sm">
          {visual.subtitulo}
        </p>

        <p class="es-subtitle mx-auto max-w-3xl text-base md:text-lg">
          {visual.frase}
        </p>

        <div class="es-divider mx-auto mt-10 w-40"></div>
      </header>

      <AudioPlayer
        src={viaje.audioUrl}
        title={viaje.titulo}
        subtitle={visual.subtitulo}
        duration={viaje.duracion}
      />

      <div class="mt-8 grid gap-8 md:grid-cols-2">
        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Propósito del viaje
          </p>

          <h2 class="titulo-ritual mb-4">
            El clima que propone esta escucha
          </h2>

          <p class="mb-6 leading-relaxed text-white/72">
            {visual.proposito}
          </p>

          <div class="subpanel-soft rounded-[1.7rem] px-5 py-5">
            <p class="text-sm leading-relaxed text-white/70">
              {visual.frase}
            </p>
          </div>
        </section>

        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Construcción y proceso
          </p>

          <h2 class="titulo-ritual mb-5">
            Cómo está armado el recorrido
          </h2>

          <div class="space-y-5">
            <div>
              <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
                Construcción
              </p>
              <p class="leading-relaxed text-white/70">
                {visual.construccion}
              </p>
            </div>

            <div class="border-t border-[#ecdcb8]/10 pt-4">
              <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
                Proceso
              </p>
              <p class="leading-relaxed text-white/70">
                {visual.detras}
              </p>
            </div>
          </div>
        </section>
      </div>

      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_0.95fr]">
        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Recomendaciones de uso
          </p>

          <h2 class="titulo-ritual mb-5">
            Cómo entrar en la experiencia
          </h2>

          <div class="space-y-4">
            {visual.recomendaciones.map((item) => (
              <div class="subpanel-soft rounded-[1.7rem] px-5 py-5">
                <p class="text-sm leading-relaxed text-white/70">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </section>

        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Qué puede mover esta escucha
          </p>

          <h2 class="titulo-ritual mb-5">
            Efectos del recorrido
          </h2>

          <div class="space-y-4">
            {visual.durante.map((item) => (
              <div class="subpanel-soft rounded-[1.7rem] px-5 py-5">
                <p class="text-sm leading-relaxed text-white/70">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="card-viaje-destacado mt-8 rounded-[2.2rem] px-6 py-7 md:px-8">
        <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.2rem]">
          <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
          <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.06] blur-3xl"></div>
        </div>

        <div class="relative z-10 grid gap-7 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
          <div>
            <p class="eyebrow-ritual-bright mb-3">
              Sonología Ritual
            </p>

            <h2 class="titulo-viaje mb-4">
              La arquitectura que sostiene la experiencia
            </h2>

            <p class="mb-4 text-[1.02rem] leading-relaxed text-white/80">
              {visual.sonologia}
            </p>

            <p class="leading-relaxed text-white/64">
              Esta escucha forma parte de un sistema donde sonido, intención y diseño trabajan juntos para abrir estados específicos y sostener el recorrido de forma sensible.
            </p>
          </div>

          <div class="subpanel-viaje rounded-[1.8rem] px-5 py-5">
            <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
              Portal de escucha
            </p>

            <h3 class="mb-3 text-[1.55rem] font-light leading-tight text-[#ecdcb8]">
              Seguí explorando el universo sonoro
            </h3>

            <p class="mb-5 text-sm leading-relaxed text-white/70">
              Cada viaje propone un clima distinto. Podés volver a la colección completa y elegir la escucha que mejor acompañe este momento.
            </p>

            <a href="/viajes" class="cta-viaje">
              Volver a viajes
            </a>
          </div>
        </div>
      </section>

      <div class="mt-8 flex justify-center">
        <section class="card-cta-final w-full max-w-3xl rounded-[2rem] px-6 py-7 text-center md:px-8">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/46">
            Seguir explorando la tienda
          </p>

        <a href="/tienda" class="cta-viaje">
        Ir a la tienda
        </a>
        </section>
      </div>
    </div>
  </section>
</Layout>