            ))}
          </div>
        </section>

        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Propiedades de la combinación
          </p>

          <h2 class="titulo-ritual mb-5">
            Cómo dialogan sus elementos
          </h2>

          <div class="space-y-5">
            {propiedadesFinales.map((item, index) => (
              <div class={index === propiedadesFinales.length - 1 ? "border-t border-[#ecdcb8]/10 pt-4" : ""}>
                <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                  {item.titulo}
                </h3>
                <p class="leading-relaxed text-white/70">
                  {item.texto}
                </p>
              </div>
            ))}
          </div>
        </section>
      </div>

<div class="mt-8 flex justify-center">
  <section class="card-cta-final w-full max-w-3xl rounded-[2rem] px-6 py-7 text-center md:px-8">
    <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/46">
      Llevar esta experiencia
    </p>

    <p class="mx-auto mb-6 max-w-2xl text-sm leading-relaxed text-white/66">
      Una combinación artesanal pensada para abrir un clima, acompañar el espacio y profundizarse a través de la escucha.
    </p>

    <button class="cta-principal">
      Agregar al carrito
    </button>
  </section>
</div>

      {recomendacionesFinales.length > 0 && (
        <section class="card-ritual mt-8 rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Recomendaciones rituales
          </p>

          <h2 class="titulo-ritual mb-5">
            Formas de entrar en relación con la mezcla
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            {recomendacionesFinales.map((item) => (
              <div>
                <h3 class="mb-3 text-xl font-light text-[#ecdcb8]">
                  {item.titulo}
                </h3>
                <p class="leading-relaxed text-white/70">
                  {item.texto}
                </p>
              </div>
            ))}
          </div>
        </section>
      )}

      <div class="mx-auto mt-12 max-w-2xl text-center">
        <p class="text-sm leading-relaxed text-white/40">
          {visual.cierre}
        </p>
      </div>
    </div>
  </section>
</Layout>

