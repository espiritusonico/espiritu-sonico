---
import Layout from "../../layouts/Layout.astro";
import "../../styles/productos-slug.css";
import { getProductos, getProductoBySlug } from "../../lib/api";
import { mapProductoDetail } from "../../lib/mappers";
import { getProductoVisualFallback } from "../../lib/productos-contenido";
import {
  getProductoPropiedades,
  getProductoRecomendaciones,
  getProductoPrecioFormateado,
  getProductoViajeHref,
  getProductoViajeCta,
  getDots,
} from "../../lib/productos-helpers";

export async function getStaticPaths() {
  try {
    const data = await getProductos();

    const productos = Array.isArray(data)
      ? data.filter((producto) => producto.activo !== false)
      : [];

    return productos.map((producto) => ({
      params: { slug: producto.slug },
    }));
  } catch (error) {
    console.warn("No se pudieron obtener los productos para getStaticPaths:", error);
    return [];
  }
}

const { slug } = Astro.params;

let producto = null;

try {
  const productoRaw = await getProductoBySlug(slug);
  producto = mapProductoDetail(productoRaw);
} catch (error) {
  console.error(`No se pudo cargar el producto con slug "${slug}":`, error);
}

if (!producto) {
  return Astro.redirect("/tienda");
}

const visual = getProductoVisualFallback(producto);

const propiedadesFinales = getProductoPropiedades(producto, visual);
const recomendacionesFinales = getProductoRecomendaciones(producto, visual);
const precioFormateado = getProductoPrecioFormateado(producto);
const viajeHref = getProductoViajeHref(producto);
const viajeCta = getProductoViajeCta(producto);
---

<Layout title={producto ? `${producto.nombre} · ${producto.mezcla}` : "Producto"}>
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.025),transparent_45%)]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="grid gap-8 md:grid-cols-2">
  <div class="panel-hero-deep overflow-hidden rounded-[2.2rem] p-[1px] shadow-[0_18px_76px_rgba(0,0,0,0.34)]">
    <div class="relative h-full rounded-[2.1rem] bg-[#0a0610]/97 p-5 backdrop-blur-2xl md:p-6">
      <div class="flex h-full min-h-[280px] items-center justify-center rounded-[1.8rem] bg-[radial-gradient(circle_at_center,rgba(236,220,184,0.06),transparent_64%)] md:min-h-[560px]">
       {producto?.imagenUrl ? (
  <img
    src={producto.imagenUrl}
    alt={`Imagen de ${producto.mezcla}`}
    class="mx-auto max-h-[240px] w-auto object-contain drop-shadow-[0_14px_44px_rgba(0,0,0,0.42)] md:max-h-[340px] lg:max-h-[380px]"
  />
) : (
  <div class="h-[240px] w-full rounded-[1.8rem] border border-white/10 bg-white/[0.03] md:h-[340px] lg:h-[380px]"></div>
)}
      </div>
    </div>
  </div>

  <div class="panel-hero-deep overflow-hidden rounded-[2.2rem] p-[1px] shadow-[0_18px_76px_rgba(0,0,0,0.34)]">
    <aside class="flex h-full flex-col rounded-[2.1rem] bg-[#0a0610]/97 px-6 py-7 backdrop-blur-2xl md:min-h-[560px] md:px-8 md:py-8">
      <p class="mb-3 text-[11px] uppercase tracking-[0.34em] text-[#ecdcb8]/62">
        Sahumerio artesanal
      </p>

      <h1 class="es-page-title mb-3 text-4xl md:text-5xl">
  {producto.mezcla}
</h1>

      <p class="mb-6 text-sm uppercase tracking-[0.18em] text-[#ecdcb8]/48">
        {visual.resumenHero}
      </p>

      <p class="mb-7 text-base leading-relaxed text-white/72">
        {producto.descripcionCorta}
      </p>

      <div class="subpanel-profile mb-7 rounded-[1.8rem] px-5 py-5">
        <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/62">
          Perfil del sahumerio
        </p>

        <h2 class="mb-3 text-[1.35rem] font-light leading-tight text-[#ecdcb8]">
          Lectura sensible de su presencia
        </h2>

        <p class="mb-6 max-w-[34rem] text-sm leading-relaxed text-white/58">
          {visual.perfilIntro}
        </p>

        <div class="space-y-4">
          {visual.perfil.map((item) => (
            <div class="perfil-row">
              <span class="perfil-label">
                {item.label}
              </span>

              <span class="perfil-line"></span>

              <div class="flex items-center gap-1.5 pl-2">
                {getDots(item.value).map((estado) => (
                  <span
                    class:list={[
                      "nivel-dot",
                      estado === "full" && "nivel-dot--full",
                      estado === "half" && "nivel-dot--half",
                    ]}
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-auto border-t border-[#ecdcb8]/10 pt-5">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-[#ecdcb8]/40">
              Precio
            </p>
            <p class="text-base text-[#ecdcb8]/92">
              {precioFormateado}
            </p>
          </div>

          <button class="cta-principal">
            Agregar al carrito
          </button>
        </div>
      </div>
    </aside>
  </div>
</div>

      <section class="card-ritual mt-8 rounded-[2.2rem] px-6 py-7 md:px-8">
        <div class="grid gap-7 lg:grid-cols-[1.05fr_0.95fr]">
          <div>
            <p class="eyebrow-ritual">
              {visual.presenciaEyebrow}
            </p>

            <h2 class="titulo-ritual mb-4">
              {visual.presenciaTitulo}
            </h2>

            <p class="mb-4 leading-relaxed text-white/72">
              {visual.presenciaTexto1}
            </p>

            <p class="leading-relaxed text-white/62">
              {visual.presenciaTexto2}
            </p>
          </div>

          <div class="subpanel-soft rounded-[1.7rem] px-5 py-5">
            <div class="mb-5">
              <p class="eyebrow-mini mb-2">
                Carácter del sahumerio
              </p>
              <p class="text-[15px] leading-relaxed text-white/76">
                {visual.caracter}
              </p>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <p class="eyebrow-mini mb-2">
                  Momento ideal
                </p>
                <p class="text-sm leading-relaxed text-white/68">
                  {visual.momentoIdeal}
                </p>
              </div>

              <div>
                <p class="eyebrow-mini mb-2">
                  Elaboración
                </p>
                <p class="text-sm leading-relaxed text-white/68">
                  Elaborado con resinas molidas a mano y hierbas seleccionadas.
                </p>
              </div>
            </div>
           </div>
        </div>
      </section>

      <section class="card-viaje-destacado mt-8 rounded-[2.2rem] px-6 py-7 md:px-8">
  <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.2rem]">
    <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-44 w-44 rounded-full bg-violet-300/[0.06] blur-3xl"></div>
  </div>

  <div class="relative z-10 grid gap-7 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
    <div>
      <p class="eyebrow-ritual-bright mb-3">
        Viaje sonoro asociado
      </p>

      <h2 class="titulo-viaje mb-4">
        La experiencia no termina en el humo
      </h2>

      <p class="mb-4 text-[1.02rem] leading-relaxed text-white/80">
        {visual.viajeDestacado}
      </p>

      <p class="leading-relaxed text-white/64">
        La propuesta de Espíritu Sónico une presencia material y arquitectura sonora. Este sahumerio puede profundizarse a través de una escucha asociada, pensada para prolongar su clima, ampliar su resonancia y abrir una experiencia más inmersiva.
      </p>
    </div>

    <div class="subpanel-viaje rounded-[1.8rem] px-5 py-5">
      <p class="mb-2 text-[11px] uppercase tracking-[0.26em] text-[#ecdcb8]/58">
        Portal de escucha
      </p>

      <h3 class="mb-3 text-[1.55rem] font-light leading-tight text-[#ecdcb8]">
        {producto.viajeSonoroTitulo || "Explorá el universo sonoro"}
      </h3>

      <p class="mb-5 text-sm leading-relaxed text-white/70">
        {producto.viajeSonoroTexto || "Podés acceder a un viaje asociado o recorrer la colección completa para elegir la escucha que mejor acompañe tu momento."}
      </p>

      <a href={viajeHref} class="cta-viaje">
        {viajeCta}
      </a>
    </div>
  </div>
</section>

      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_0.95fr]">
        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Descripción
          </p>

          <h2 class="titulo-ritual mb-5">
            {visual.descripcionTitulo}
          </h2>

          <div class="space-y-4 leading-relaxed text-white/72">
            {visual.descripcionParrafos.map((parrafo) => (
              <p>{parrafo}</p>
            ))}
          </div>
        </section>

        <section class="card-ritual rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Propiedades de la combinación
          </p>

          <h2 class="titulo-ritual mb-5">
            Cómo dialogan sus elementos
          </h2>

          <div class="space-y-5">
            {propiedadesFinales.map((item, index) => (
              <div class={index === propiedadesFinales.length - 1 ? "border-t border-[#ecdcb8]/10 pt-4" : ""}>
                <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                  {item.titulo}
                </h3>
                <p class="leading-relaxed text-white/70">
                  {item.texto}
                </p>
              </div>
            ))}
          </div>
        </section>
      </div>

<div class="mt-8 flex justify-center">
  <section class="card-cta-final w-full max-w-3xl rounded-[2rem] px-6 py-7 text-center md:px-8">
    <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/46">
      Llevar esta experiencia
    </p>

    <p class="mx-auto mb-6 max-w-2xl text-sm leading-relaxed text-white/66">
      Una combinación artesanal pensada para abrir un clima, acompañar el espacio y profundizarse a través de la escucha.
    </p>

    <button class="cta-principal">
      Agregar al carrito
    </button>
  </section>
</div>

      {recomendacionesFinales.length > 0 && (
        <section class="card-ritual mt-8 rounded-[2.2rem] px-6 py-7 md:px-8">
          <p class="eyebrow-ritual">
            Recomendaciones rituales
          </p>

          <h2 class="titulo-ritual mb-5">
            Formas de entrar en relación con la mezcla
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            {recomendacionesFinales.map((item) => (
              <div>
                <h3 class="mb-3 text-xl font-light text-[#ecdcb8]">
                  {item.titulo}
                </h3>
                <p class="leading-relaxed text-white/70">
                  {item.texto}
                </p>
              </div>
            ))}
          </div>
        </section>
      )}

      <div class="mx-auto mt-12 max-w-2xl text-center">
        <p class="text-sm leading-relaxed text-white/40">
          {visual.cierre}
        </p>
      </div>
    </div>
  </section>
</Layout>

