---
import Layout from "../../layouts/Layout.astro";

const destacados = [
  {
    etiqueta: "Acceso gratuito",
    titulo: "Sistema de Prompts — versión inicial",
    descripcion:
      "Una entrada clara al método para empezar a explorar procesos creativos guiados con inteligencia artificial.",
    href: "#",
    cta: "Acceder",
    acceso: "Gratis",
  },
  {
    etiqueta: "Próximo acceso premium",
    titulo: "Sistema de Prompts — versión completa",
    descripcion:
      "Un recorrido expandido para ordenar intuiciones, desarrollar propuestas y transformar ideas en estructura real.",
    href: "#",
    cta: "Ver más",
    acceso: "Próximamente",
  },
];

const sahumerios = [
  {
    nombre: "Lavanda, Eucaliptus y Menta",
    descripcion: "Frescura herbal para despejar, limpiar y renovar el espacio.",
    href: "/tienda/sahumerio/lavanda",
    cta: "Ver producto",
    acceso: "Próximamente",
  },
  {
    nombre: "Salvia, Benjuí y Palo Santo",
    descripcion: "Profundidad ritual para protección, purificación y apertura.",
    href: "/tienda/sahumerio/salvia",
    cta: "Ver producto",
    acceso: "Próximamente",
  },
  {
    nombre: "Tercera variedad",
    descripcion: "Nueva combinación en preparación para ampliar la línea.",
    href: "#",
    cta: "Próximamente",
    acceso: "En preparación",
  },
];

const digitales = [
  {
    nombre: "Pack de 12 cursos",
    tipo: "Formación digital",
    descripcion: "Un recorrido para integrar la ancestralidad en la vida diaria.",
    href: "#",
    cta: "Ver formación",
    acceso: "Próximamente",
  },
  {
    nombre: "El arte del sigilo",
    tipo: "Libro digital",
    descripcion: "Guía simbólica y práctica actualmente en revisión final.",
    href: "#",
    cta: "Ver libro",
    acceso: "Próximamente",
  },
];
---

<Layout title="Tienda">
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-8 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl">
      <header class="mb-14 text-center md:mb-16">
        <p class="mb-4 text-[11px] uppercase tracking-[0.42em] text-[#ecdcb8]/55">
          Espíritu Sónico
        </p>

        <h1 class="mx-auto mb-5 max-w-4xl text-4xl font-light leading-tight text-[#ecdcb8] md:text-6xl">
          Tienda
        </h1>

        <p class="mx-auto max-w-2xl text-sm leading-relaxed text-white/68 md:text-base">
          Objetos rituales, accesos digitales y materiales de estudio reunidos en un mismo espacio.
        </p>

        <div class="mx-auto mt-8 h-px w-24 bg-gradient-to-r from-transparent via-[#ecdcb8]/60 to-transparent"></div>
      </header>

      <section class="mb-16 grid gap-5 lg:grid-cols-2">
        {destacados.map((item) => (
          <article class="group relative overflow-hidden rounded-[2.2rem] border border-[#ecdcb8]/15 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] p-[1px] shadow-[0_14px_60px_rgba(0,0,0,0.22)] transition duration-500 hover:-translate-y-1 hover:border-[#ecdcb8]/30">
            <div class="relative h-full rounded-[2.1rem] bg-[#120a18]/85 px-6 py-7 backdrop-blur-2xl md:px-8 md:py-8">
              <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.1rem]">
                <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.08] blur-3xl"></div>
                <div class="absolute bottom-0 right-0 h-36 w-36 rounded-full bg-violet-300/[0.07] blur-3xl"></div>
              </div>

              <div class="relative z-10 flex h-full flex-col">
                <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/70">
                  {item.etiqueta}
                </p>

                <h2 class="mb-4 max-w-xl text-2xl font-light leading-tight text-[#ecdcb8] md:text-[2rem]">
                  {item.titulo}
                </h2>

                <p class="mb-8 max-w-xl text-sm leading-relaxed text-white/72 md:text-[15px]">
                  {item.descripcion}
                </p>

                <div class="mt-auto flex items-end justify-between gap-4 border-t border-white/10 pt-5">
                  <div>
                    <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/30">
                      Acceso
                    </p>
                    <p class="text-sm text-[#ecdcb8]/90">
                      {item.acceso}
                    </p>
                  </div>

                  <a
                    href={item.href}
                    class="inline-flex items-center justify-center rounded-full border border-[#ecdcb8]/35 px-5 py-2.5 text-sm tracking-[0.06em] text-[#ecdcb8] transition duration-300 hover:border-[#ecdcb8]/55 hover:bg-[#ecdcb8]/10"
                  >
                    {item.cta}
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))}
      </section>

      <section class="mb-16">
        <div class="mb-7 flex items-end justify-between gap-4">
          <div>
            <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-white/35">
              Colección
            </p>
            <h2 class="text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Objetos rituales
            </h2>
          </div>

          <p class="hidden max-w-sm text-right text-sm leading-relaxed text-white/45 md:block">
            Piezas físicas para acompañar pausas, limpiezas y experiencias sensoriales.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {sahumerios.map((item) => (
  <article class="group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-[1px] transition duration-500 hover:-translate-y-1 hover:border-white/20">
    <div class="flex h-full flex-col rounded-[1.95rem] bg-[#120a18]/80 px-6 py-7 backdrop-blur-xl">
      <div class="mb-8">
        <div class="mb-5 flex items-center justify-between gap-3">
          <span class="text-[10px] uppercase tracking-[0.28em] text-white/35">
            objeto ritual
          </span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#ecdcb8]/70 shadow-[0_0_12px_rgba(236,220,184,0.35)]"></span>
        </div>

        <h3 class="mb-4 text-2xl font-light leading-tight text-[#ecdcb8]">
          {item.nombre}
        </h3>

        <p class="max-w-xs text-sm leading-relaxed text-white/70">
          {item.descripcion}
        </p>
      </div>

      <div class="mt-auto flex items-end justify-between gap-4 border-t border-white/10 pt-5">
        <div>
          <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/30">
            Estado
          </p>
          <p class="text-sm text-[#ecdcb8]/85">
            {item.acceso}
          </p>
        </div>

        <a
          href={item.href}
          class="inline-flex items-center justify-center rounded-full border border-[#ecdcb8]/35 px-5 py-2.5 text-sm tracking-[0.06em] text-[#ecdcb8] transition duration-300 hover:border-[#ecdcb8]/55 hover:bg-[#ecdcb8]/10"
        >
          Ver producto
        </a>
      </div>
    </div>
  </article>
))}
        </div>
      </section>

      <section>
        <div class="mb-7 flex items-end justify-between gap-4">
          <div>
            <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-white/35">
              Colección
            </p>
            <h2 class="text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Biblioteca viva
            </h2>
          </div>

          <p class="hidden max-w-sm text-right text-sm leading-relaxed text-white/45 md:block">
            Herramientas, formación y materiales de profundización para expandir el trabajo interno y creativo.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {digitales.map((item) => (
            <article class="group relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-[1px] transition duration-500 hover:-translate-y-1 hover:border-white/20">
              <div class="flex h-full flex-col rounded-[1.95rem] bg-[#120a18]/80 px-6 py-7 backdrop-blur-xl">
                <div class="mb-8">
                  <div class="mb-5 flex items-center justify-between gap-3">
                    <span class="text-[10px] uppercase tracking-[0.28em] text-white/35">
                      {item.tipo}
                    </span>
                    <span class="h-2.5 w-2.5 rounded-full bg-violet-300/70 shadow-[0_0_12px_rgba(196,181,253,0.35)]"></span>
                  </div>

                  <h3 class="mb-4 text-2xl font-light leading-tight text-[#ecdcb8]">
                    {item.nombre}
                  </h3>

                  <p class="max-w-md text-sm leading-relaxed text-white/70">
                    {item.descripcion}
                  </p>
                </div>

                <div class="mt-auto flex items-end justify-between gap-4 border-t border-white/10 pt-5">
                  <div>
                    <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/30">
                      Acceso
                    </p>
                    <p class="text-sm text-[#ecdcb8]/85">
                      {item.acceso}
                    </p>
                  </div>

                  <a
                    href={item.href}
                    class="inline-flex items-center justify-center rounded-full border border-white/10 px-5 py-2.5 text-sm tracking-[0.06em] text-white/45 transition duration-300 hover:border-white/20 hover:bg-white/5"
                  >
                    {item.cta}
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</Layout>