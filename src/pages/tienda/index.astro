---
import Layout from "../../layouts/Layout.astro";

const recursosGratuitos = [
  {
    etiqueta: "Acceso gratuito",
    titulo: "Sistema de Prompts — versión inicial",
    descripcion:
      "Una entrada clara al método para empezar a explorar procesos creativos guiados con inteligencia artificial.",
    href: "#",
    cta: "Acceder",
  },
  {
    etiqueta: "Acceso gratuito",
    titulo: "Aprender a armar tu propio altar",
    descripcion:
      "Un recurso inicial para empezar a crear un espacio simbólico, simple y significativo dentro de la vida cotidiana.",
    href: "#",
    cta: "Acceder",
  },
];

const sahumerios = [
  {
    nombre: "Lavanda, Eucaliptus y Menta",
    descripcion:
      "Sahumerio musical para despejar, limpiar y renovar el espacio, acompañado por un viaje sonoro exclusivo.",
    href: "/tienda/sahumerio/lavanda",
    imagen: "/iconos/icon-sahumerio.png",
    estado: "Próximamente",
    tipo: "Sahumerio musical",
  },
  {
    nombre: "Salvia, Benjuí y Palo Santo",
    descripcion:
      "Sahumerio musical para protección, purificación y apertura, acompañado por un viaje sonoro exclusivo.",
    href: "/tienda/sahumerio/salvia",
    imagen: "/iconos/icon-sahumerio.png",
    estado: "Próximamente",
    tipo: "Sahumerio musical",
  },
  {
    nombre: "Tercera variedad",
    descripcion:
      "Nueva pieza de la línea de sahumerios musicales, creada para ampliar la experiencia ritual junto a un viaje sonoro.",
    href: "#",
    imagen: "/iconos/icon-sahumerio.png",
    estado: "En preparación",
    tipo: "Sahumerio musical",
  },
];

const bibliotecaViva = [
  {
    tipo: "Próximo acceso premium",
    nombre: "Sistema de Prompts — versión completa",
    descripcion:
      "Un recorrido expandido para ordenar intuiciones, desarrollar propuestas y transformar ideas en estructura real.",
    href: "#",
    cta: "Ver más",
    acceso: "Próximamente",
  },
  {
    tipo: "Formación digital",
    nombre: "Pack de 12 cursos",
    descripcion:
      "Un recorrido para integrar la ancestralidad en la vida diaria.",
    href: "#",
    cta: "Ver formación",
    acceso: "Próximamente",
  },
  {
    tipo: "Libro digital",
    nombre: "El arte del sigilo",
    descripcion:
      "Guía simbólica y práctica actualmente en revisión final.",
    href: "#",
    cta: "Ver libro",
    acceso: "Próximamente",
  },
];
---

<Layout title="Tienda">
  <section class="relative min-h-screen overflow-hidden px-4 pb-24 pt-14 text-white sm:px-5 md:px-6 md:pt-16">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-[24rem] w-[24rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.045] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl">
      <header class="mb-10 text-center md:mb-12">
        <h1 class="mx-auto mb-4 max-w-4xl text-4xl font-light leading-tight text-[#ecdcb8] md:text-6xl">
          Tienda
        </h1>

        <p class="mx-auto max-w-3xl text-[17px] leading-8 text-[#ecdcb8]/78 md:text-[19px]">
          Objetos rituales, accesos digitales y materiales de estudio reunidos en un mismo espacio.
        </p>

        <div class="mx-auto mt-7 h-px w-24 bg-gradient-to-r from-transparent via-[#ecdcb8]/55 to-transparent"></div>
      </header>

      <section class="relative mb-8 overflow-hidden rounded-[2.4rem] bg-[linear-gradient(180deg,rgba(236,220,184,0.045),rgba(255,255,255,0.012))] px-4 py-4 shadow-[0_20px_70px_rgba(0,0,0,0.2)] backdrop-blur-xl sm:px-5 md:px-6">
        <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.4rem]">
          <div class="absolute left-0 top-0 h-32 w-32 rounded-full bg-[#ecdcb8]/[0.04] blur-3xl"></div>
          <div class="absolute right-0 top-8 h-28 w-28 rounded-full bg-violet-300/[0.05] blur-3xl"></div>
        </div>

        <div class="relative z-10 flex flex-col gap-4">
          <div class="relative">
            <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[#ecdcb8]/48">
              ⌕
            </span>
            <input
              id="shop-search"
              type="text"
              placeholder="Explorar sahumerios, recursos y materiales"
              class="w-full rounded-full bg-[#120a18]/80 py-3 pl-11 pr-4 text-[15px] text-[#ecdcb8] placeholder:text-[#ecdcb8]/36 shadow-[inset_0_0_0_1px_rgba(236,220,184,0.08)] outline-none transition duration-300 focus:shadow-[inset_0_0_0_1px_rgba(236,220,184,0.18),0_0_0_6px_rgba(236,220,184,0.04)]"
            />
          </div>

          <div class="flex flex-wrap gap-2">
            <button type="button" data-filter="all" class="shop-filter rounded-full bg-[#ecdcb8]/12 px-4 py-2 text-[13px] text-[#ecdcb8] ring-1 ring-[#ecdcb8]/18 transition duration-300 hover:bg-[#ecdcb8]/16 active:scale-[0.98]">
              Todos
            </button>
            <button type="button" data-filter="gratuitos" class="shop-filter rounded-full bg-white/[0.04] px-4 py-2 text-[13px] text-white/72 ring-1 ring-white/8 transition duration-300 hover:bg-white/[0.07] active:scale-[0.98]">
              Gratuitos
            </button>
            <button type="button" data-filter="rituales" class="shop-filter rounded-full bg-white/[0.04] px-4 py-2 text-[13px] text-white/72 ring-1 ring-white/8 transition duration-300 hover:bg-white/[0.07] active:scale-[0.98]">
              Objetos rituales
            </button>
            <button type="button" data-filter="biblioteca" class="shop-filter rounded-full bg-white/[0.04] px-4 py-2 text-[13px] text-white/72 ring-1 ring-white/8 transition duration-300 hover:bg-white/[0.07] active:scale-[0.98]">
              Biblioteca viva
            </button>
          </div>
        </div>
      </section>

      <section
        class="shop-section relative mb-8 overflow-hidden rounded-[2.4rem] bg-[linear-gradient(180deg,rgba(236,220,184,0.04),rgba(255,255,255,0.012))] shadow-[0_18px_60px_rgba(0,0,0,0.18)] backdrop-blur-xl"
        data-section="gratuitos"
      >
        <button
          type="button"
          class="shop-toggle flex w-full items-start justify-between gap-4 px-4 py-5 text-left sm:px-5 md:px-7 md:py-6"
          aria-expanded="false"
        >
          <div class="max-w-2xl">
            <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-white/34">
              Acceso inicial
            </p>
            <h2 class="mb-3 text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Recursos gratuitos
            </h2>
            <p class="max-w-2xl text-[14px] italic leading-7 text-[#ecdcb8]/46 md:text-[14.5px]">
              Recursos de entrada para comenzar a explorar el universo de Espíritu Sónico desde una experiencia simple, abierta y accesible.
            </p>
          </div>

          <span class="shop-chevron mt-1 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white/[0.04] text-white/70 ring-1 ring-white/8 transition duration-300">
            ˅
          </span>
        </button>

        <div class="shop-panel grid transition-[grid-template-rows] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" style="grid-template-rows: 0fr;">
          <div class="overflow-hidden">
            <div class="px-4 pb-5 sm:px-5 md:px-7 md:pb-7">
              <div class="mb-6 h-px bg-gradient-to-r from-transparent via-[#ecdcb8]/18 to-transparent"></div>

              <div class="grid gap-4 md:grid-cols-2 md:gap-5">
                {recursosGratuitos.map((item) => (
                  <a
                    href={item.href}
                    data-item
                    data-category="gratuitos"
                    data-search={`${item.titulo} ${item.descripcion} ${item.etiqueta}`}
                    class="group/resource relative overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(236,220,184,0.10),rgba(168,85,247,0.03))] p-[1px] shadow-[0_12px_42px_rgba(0,0,0,0.18)] transition duration-500 hover:-translate-y-1 active:scale-[0.985] active:translate-y-[1px]"
                  >
                    <div class="relative h-full rounded-[1.92rem] bg-[linear-gradient(180deg,rgba(18,10,24,0.95),rgba(24,13,32,0.88))] px-4 py-5 backdrop-blur-2xl sm:px-5 sm:py-6 md:px-6 md:py-7">
                      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[1.92rem]">
                        <div class="absolute -left-10 top-0 h-40 w-40 rounded-full bg-[#ecdcb8]/[0.08] blur-3xl transition duration-500 group-hover/resource:bg-[#ecdcb8]/[0.12] group-active/resource:bg-[#ecdcb8]/[0.12]"></div>
                        <div class="absolute bottom-0 right-0 h-32 w-32 rounded-full bg-violet-300/[0.07] blur-3xl"></div>
                        <div class="absolute inset-[1px] rounded-[1.84rem] ring-1 ring-[#ecdcb8]/10 transition duration-500 group-hover/resource:ring-[#ecdcb8]/18 group-active/resource:ring-[#ecdcb8]/18"></div>
                      </div>

                      <div class="relative z-10 flex h-full flex-col">
                        <div class="mb-4 flex items-center justify-between gap-3">
                          <p class="text-[11px] uppercase tracking-[0.28em] text-[#ecdcb8]/68">
                            {item.etiqueta}
                          </p>

                          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#ecdcb8]/6 text-[#ecdcb8]/75 ring-1 ring-[#ecdcb8]/15 transition duration-300 group-hover/resource:bg-[#ecdcb8]/12 group-hover/resource:text-[#ecdcb8] group-active/resource:bg-[#ecdcb8]/12 group-active/resource:text-[#ecdcb8]">
                            ↗
                          </span>
                        </div>

                        <h3 class="mb-3 text-[1.45rem] font-light leading-tight text-[#ecdcb8] sm:text-[1.6rem] md:text-[1.85rem]">
                          {item.titulo}
                        </h3>

                        <p class="mb-6 text-[14.5px] leading-6 text-white/78 sm:text-[15px] sm:leading-7 md:text-[15.5px]">
                          {item.descripcion}
                        </p>

                        <div class="mt-auto flex items-end justify-between gap-4 border-t border-[#ecdcb8]/10 pt-5">
                          <div>
                            <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/38">
                              Acceso
                            </p>
                            <p class="text-sm text-[#ecdcb8]/92">
                              Gratuito
                            </p>
                          </div>

                          <span class="text-sm tracking-[0.06em] text-[#ecdcb8] transition duration-300 group-hover/resource:text-white group-active/resource:text-white">
                            {item.cta}
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section
        class="shop-section relative mb-8 overflow-hidden rounded-[2.4rem] bg-[linear-gradient(180deg,rgba(236,220,184,0.05),rgba(90,60,120,0.018))] shadow-[0_22px_70px_rgba(0,0,0,0.2)] backdrop-blur-xl"
        data-section="rituales"
      >
        <button
          type="button"
          class="shop-toggle flex w-full items-start justify-between gap-4 px-4 py-5 text-left sm:px-5 md:px-7 md:py-6"
          aria-expanded="false"
        >
          <div class="max-w-2xl">
            <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-white/34">
              Colección
            </p>
            <h2 class="mb-3 text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Objetos rituales
            </h2>
            <p class="max-w-2xl text-[14px] italic leading-7 text-[#ecdcb8]/46 md:text-[14.5px]">
              Sahumerios musicales y piezas rituales concebidas para acompañar procesos de limpieza, pausa y escucha.
            </p>
          </div>

          <span class="shop-chevron mt-1 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#ecdcb8]/8 text-[#ecdcb8]/75 ring-1 ring-[#ecdcb8]/12 transition duration-300">
            ˅
          </span>
        </button>

        <div class="shop-panel grid transition-[grid-template-rows] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" style="grid-template-rows: 0fr;">
          <div class="overflow-hidden">
            <div class="px-4 pb-5 sm:px-5 md:px-7 md:pb-7">
              <div class="mb-6 h-px bg-gradient-to-r from-transparent via-[#ecdcb8]/22 to-transparent"></div>

              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {sahumerios.map((item) => (
                  <a
                    href={item.href}
                    data-item
                    data-category="rituales"
                    data-search={`${item.nombre} ${item.descripcion} ${item.tipo} ${item.estado}`}
                    class="group/card relative overflow-hidden rounded-[2.25rem] bg-[linear-gradient(180deg,rgba(236,220,184,0.08),rgba(120,86,162,0.035))] p-[1px] shadow-[0_20px_60px_rgba(0,0,0,0.24)] transition duration-500 hover:-translate-y-1.5 active:scale-[0.985] active:translate-y-[1px]"
                  >
                    <div class="relative flex h-full min-h-[24.5rem] flex-col rounded-[2.18rem] bg-[linear-gradient(180deg,rgba(18,10,24,0.95),rgba(24,13,32,0.89))] px-4 pb-5 pt-4 backdrop-blur-2xl sm:min-h-[26rem] sm:px-5 sm:pb-6 sm:pt-5">
                      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.18rem]">
                        <div class="absolute left-1/2 top-8 h-44 w-44 -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.08] blur-3xl transition duration-500 group-hover/card:bg-[#ecdcb8]/[0.14] group-active/card:bg-[#ecdcb8]/[0.14]"></div>
                        <div class="absolute -left-6 bottom-10 h-28 w-28 rounded-full bg-violet-400/[0.08] blur-3xl"></div>
                        <div class="absolute bottom-0 right-0 h-36 w-36 rounded-full bg-fuchsia-300/[0.06] blur-3xl"></div>
                        <div class="absolute inset-[1px] rounded-[2.05rem] ring-1 ring-[#ecdcb8]/10 transition duration-500 group-hover/card:ring-[#ecdcb8]/20 group-active/card:ring-[#ecdcb8]/20"></div>
                      </div>

                      <div class="relative z-10 mb-5 flex items-center justify-between gap-3">
                        <span class="text-[10px] uppercase tracking-[0.26em] text-[#ecdcb8]/62">
                          {item.tipo}
                        </span>

                        <span class="rounded-full bg-[#ecdcb8]/10 px-2.5 py-1 text-[10px] uppercase tracking-[0.18em] text-[#ecdcb8]/75 ring-1 ring-[#ecdcb8]/15">
                          {item.estado}
                        </span>
                      </div>

                      <div class="relative z-10 flex min-h-[10.5rem] items-center justify-center sm:min-h-[12rem]">
                        <img
                          src={item.imagen}
                          alt={item.nombre}
                          class="max-h-[12rem] w-auto object-contain drop-shadow-[0_0_32px_rgba(236,220,184,0.18)] transition duration-500 group-hover/card:scale-[1.05] group-active/card:scale-[1.03]"
                        />
                      </div>

                      <div class="relative z-10 mt-2 flex flex-1 flex-col">
                        <h3 class="mb-3 text-[1.35rem] font-light leading-tight text-[#ecdcb8] sm:text-[1.5rem]">
                          {item.nombre}
                        </h3>

                        <p class="mb-3 text-[14.5px] leading-6 text-white/78 sm:text-[15px] sm:leading-7 md:text-[15.5px]">
                          {item.descripcion}
                        </p>

                        <p class="mb-5 text-[12.5px] leading-5 text-[#ecdcb8]/72 sm:text-[13.5px] sm:leading-6 md:text-[14px]">
                          Incluye acceso a un viaje sonoro asociado.
                        </p>

                        <div class="mt-auto flex items-center justify-between gap-4 border-t border-[#ecdcb8]/10 pt-5">
                          <span class="text-sm text-[#ecdcb8]/82 transition duration-300 group-hover/card:text-[#ecdcb8] group-active/card:text-[#ecdcb8]">
                            Entrar al producto
                          </span>

                          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#ecdcb8]/6 text-[#ecdcb8]/80 ring-1 ring-[#ecdcb8]/15 transition duration-300 group-hover/card:bg-[#ecdcb8]/12 group-hover/card:text-[#ecdcb8] group-active/card:bg-[#ecdcb8]/12 group-active/card:text-[#ecdcb8]">
                            →
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section
        class="shop-section relative overflow-hidden rounded-[2.4rem] bg-[linear-gradient(180deg,rgba(139,92,246,0.07),rgba(236,220,184,0.014))] shadow-[0_20px_65px_rgba(0,0,0,0.18)] backdrop-blur-xl"
        data-section="biblioteca"
      >
        <button
          type="button"
          class="shop-toggle flex w-full items-start justify-between gap-4 px-4 py-5 text-left sm:px-5 md:px-7 md:py-6"
          aria-expanded="false"
        >
          <div class="max-w-2xl">
            <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-white/34">
              Colección
            </p>
            <h2 class="mb-3 text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Biblioteca viva
            </h2>
            <p class="max-w-2xl text-[14px] italic leading-7 text-[#ecdcb8]/46 md:text-[14.5px]">
              Materiales de estudio, formación y exploración simbólica para profundizar procesos internos, creativos y rituales.
            </p>
          </div>

          <span class="shop-chevron mt-1 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-violet-300/10 text-violet-100/70 ring-1 ring-violet-200/12 transition duration-300">
            ˅
          </span>
        </button>

        <div class="shop-panel grid transition-[grid-template-rows] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" style="grid-template-rows: 0fr;">
          <div class="overflow-hidden">
            <div class="px-4 pb-5 sm:px-5 md:px-7 md:pb-7">
              <div class="mb-6 h-px bg-gradient-to-r from-transparent via-violet-200/24 to-transparent"></div>

              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {bibliotecaViva.map((item) => (
                  <a
                    href={item.href}
                    data-item
                    data-category="biblioteca"
                    data-search={`${item.nombre} ${item.descripcion} ${item.tipo} ${item.acceso}`}
                    class="group/library relative overflow-hidden rounded-[2.15rem] bg-[linear-gradient(180deg,rgba(139,92,246,0.11),rgba(236,220,184,0.045))] p-[1px] shadow-[0_18px_54px_rgba(0,0,0,0.22)] transition duration-500 hover:-translate-y-1 active:scale-[0.985] active:translate-y-[1px]"
                  >
                    <div class="relative flex h-full min-h-[17.5rem] flex-col rounded-[2.08rem] bg-[linear-gradient(180deg,rgba(16,9,22,0.95),rgba(22,12,30,0.89))] px-4 py-5 backdrop-blur-xl sm:min-h-[19rem] sm:px-5 sm:py-6 md:px-6 md:py-7">
                      <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.08rem]">
                        <div class="absolute -right-10 top-0 h-32 w-32 rounded-full bg-violet-300/[0.10] blur-3xl transition duration-500 group-hover/library:bg-violet-300/[0.15] group-active/library:bg-violet-300/[0.15]"></div>
                        <div class="absolute left-0 top-1/2 h-28 w-28 -translate-y-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
                        <div class="absolute bottom-0 left-1/3 h-24 w-24 rounded-full bg-fuchsia-300/[0.05] blur-3xl"></div>
                        <div class="absolute inset-[1px] rounded-[1.96rem] ring-1 ring-violet-200/10 transition duration-500 group-hover/library:ring-violet-200/20 group-active/library:ring-violet-200/20"></div>
                      </div>

                      <div class="relative z-10 mb-5 flex items-start justify-between gap-3">
                        <div>
                          <p class="mb-2 text-[10px] uppercase tracking-[0.28em] text-violet-200/55">
                            {item.tipo}
                          </p>
                          <div class="h-px w-12 bg-gradient-to-r from-violet-200/40 to-transparent"></div>
                        </div>

                        <span class="mt-1 inline-flex h-9 w-9 items-center justify-center rounded-full bg-violet-300/10 text-violet-100/70 ring-1 ring-violet-200/15 transition duration-300 group-hover/library:bg-violet-300/16 group-hover/library:text-violet-100 group-active/library:bg-violet-300/16 group-active/library:text-violet-100">
                          ✦
                        </span>
                      </div>

                      <div class="relative z-10 flex flex-1 flex-col">
                        <h3 class="mb-3 text-[1.38rem] font-light leading-tight text-[#ecdcb8] sm:text-[1.55rem] md:text-[1.7rem]">
                          {item.nombre}
                        </h3>

                        <p class="mb-6 text-[14.5px] leading-6 text-white/78 sm:text-[15px] sm:leading-7 md:text-[15.5px]">
                          {item.descripcion}
                        </p>

                        <div class="mt-auto flex items-end justify-between gap-4 border-t border-violet-200/10 pt-5">
                          <div>
                            <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/38">
                              Acceso
                            </p>
                            <p class="text-sm text-[#ecdcb8]/85">
                              {item.acceso}
                            </p>
                          </div>

                          <span class="inline-flex items-center justify-center rounded-full bg-white/[0.04] px-5 py-2.5 text-sm tracking-[0.06em] text-white/68 ring-1 ring-white/10 transition duration-300 group-hover/library:bg-white/[0.07] group-hover/library:text-white/88 group-hover/library:ring-white/16 group-active/library:bg-white/[0.07] group-active/library:text-white/88">
                            {item.cta}
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>

<script>
  const initShop = () => {
    const searchInput = document.querySelector('#shop-search');
    const filterButtons = Array.from(document.querySelectorAll('.shop-filter'));
    const sections = Array.from(document.querySelectorAll('.shop-section'));

    let activeFilter = 'all';

    const setPanelState = (section, open) => {
      const button = section.querySelector('.shop-toggle');
      const panel = section.querySelector('.shop-panel');
      const chevron = section.querySelector('.shop-chevron');
      if (!button || !panel || !chevron) return;

      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.style.gridTemplateRows = open ? '1fr' : '0fr';
      chevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
    };

    const updateFiltersUI = () => {
      filterButtons.forEach((btn) => {
        const isActive = btn.dataset.filter === activeFilter;
        btn.classList.toggle('bg-[#ecdcb8]/12', isActive);
        btn.classList.toggle('text-[#ecdcb8]', isActive);
        btn.classList.toggle('ring-[#ecdcb8]/18', isActive);
        btn.classList.toggle('bg-white/[0.04]', !isActive);
        btn.classList.toggle('text-white/72', !isActive);
        btn.classList.toggle('ring-white/8', !isActive);
      });
    };

    const applySearchAndFilter = () => {
      const query = (searchInput?.value || '').trim().toLowerCase();

      sections.forEach((section) => {
        const sectionName = section.dataset.section || '';
        const items = Array.from(section.querySelectorAll('[data-item]'));
        let visibleCount = 0;

        items.forEach((item) => {
          const category = item.dataset.category || '';
          const searchable = (item.dataset.search || '').toLowerCase();
          const matchFilter = activeFilter === 'all' || category === activeFilter;
          const matchSearch = !query || searchable.includes(query);
          const visible = matchFilter && matchSearch;

          item.style.display = visible ? '' : 'none';
          if (visible) visibleCount++;
        });

        if (activeFilter !== 'all' && activeFilter !== sectionName && !query) {
          section.style.display = 'none';
          return;
        }

        section.style.display = '';

        if (query || activeFilter !== 'all') {
          setPanelState(section, visibleCount > 0);
        }
      });
    };

    sections.forEach((section) => {
      const button = section.querySelector('.shop-toggle');
      if (!button) return;

      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        setPanelState(section, !isOpen);
      });

      setPanelState(section, false);
    });

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter || 'all';
        updateFiltersUI();
        applySearchAndFilter();
      });
    });

    searchInput?.addEventListener('input', applySearchAndFilter);

    updateFiltersUI();
    applySearchAndFilter();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShop);
  } else {
    initShop();
  }
</script>