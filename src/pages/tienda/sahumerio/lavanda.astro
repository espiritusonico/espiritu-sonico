---
import Layout from "../../../layouts/Layout.astro";

const perfil = [
  { label: "Frescura", value: 4.5 },
  { label: "Suavidad", value: 4 },
  { label: "Claridad", value: 4.5 },
  { label: "Profundidad", value: 2.5 },
  { label: "Apertura", value: 4 },
];
---

<Layout title="Lavanda, Eucaliptus y Menta">
  <section class="relative min-h-screen overflow-hidden px-5 pb-24 pt-20 text-white md:px-6">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-10 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-[#ecdcb8]/[0.05] blur-3xl"></div>
      <div class="absolute -left-20 top-1/3 h-72 w-72 rounded-full bg-violet-400/[0.05] blur-3xl"></div>
      <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-fuchsia-300/[0.04] blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-6xl">
      <!-- HERO -->
      <div class="grid items-stretch gap-8 md:grid-cols-2">
        <!-- IZQUIERDA: IMAGEN -->
        <div class="relative h-full overflow-hidden rounded-[2.2rem] border border-white/10 bg-white/[0.04] p-[1px]">
          <div class="h-full rounded-[2.1rem] bg-[#120a18]/80 p-5 backdrop-blur-2xl md:p-6">
            <div class="flex h-full min-h-[280px] md:min-h-[560px] items-center justify-center rounded-[1.8rem] border border-white/8 bg-[radial-gradient(circle_at_center,rgba(236,220,184,0.08),transparent_55%)]">
              <img
                src="/images/sahumerio-mini.png"
                alt="Sahumerio de Lavanda, Eucaliptus y Menta"
                class="mx-auto max-h-[240px] w-auto object-contain md:max-h-[340px] lg:max-h-[380px] drop-shadow-[0_10px_40px_rgba(0,0,0,0.35)]"
              />
            </div>
          </div>
        </div>

        <!-- DERECHA: HERO INFO -->
        <aside class="flex h-full flex-col rounded-[2.2rem] border border-white/10 bg-[#120a18]/80 px-6 py-7 backdrop-blur-2xl md:min-h-[560px] md:px-8 md:py-8">
          <p class="mb-3 text-[11px] uppercase tracking-[0.34em] text-[#ecdcb8]/65">
            Sahumerio artesanal
          </p>

          <h1 class="mb-3 text-4xl font-light leading-tight text-[#ecdcb8] md:text-5xl">
            Lavanda, Eucaliptus y Menta
          </h1>

          <p class="mb-6 text-sm uppercase tracking-[0.18em] text-white/45">
            Frescura herbal · claridad · limpieza suave
          </p>

          <p class="mb-7 text-base leading-relaxed text-white/72">
            Una combinación pensada para acompañar momentos de limpieza energética,
            renovación del ambiente y apertura de un estado más liviano, claro y respirable.
          </p>

          <div class="mb-7 rounded-[1.6rem] border border-white/8 bg-white/[0.03] px-5 py-5">
            <p class="mb-5 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/62">
              Perfil del sahumerio
            </p>

            <div class="space-y-4">
              {perfil.map((item) => {
                const fullDots = Math.floor(item.value);
                const hasHalf = item.value % 1 !== 0;
                const emptyDots = 5 - fullDots - (hasHalf ? 1 : 0);

                return (
                  <div class="grid grid-cols-[1fr_auto] items-center gap-4">
                    <span class="text-sm text-white/72">{item.label}</span>

                    <div class="flex items-center gap-2">
                      {Array.from({ length: fullDots }).map(() => (
                        <span class="inline-block w-[0.82rem] h-[0.82rem] rounded-full border border-[rgba(84,68,112,0.22)] bg-[linear-gradient(135deg,#2a2235_0%,#433750_52%,#5b4b6d_100%)]"></span>
                      ))}
                      {hasHalf && <span class="inline-block w-[0.82rem] h-[0.82rem] rounded-full border border-[rgba(84,68,112,0.22)] bg-[linear-gradient(90deg,#34293f_0%,#5b4b6d_50%,rgba(255,255,255,0.03)_50%,rgba(255,255,255,0.03)_100%)]"></span>}
                      {Array.from({ length: emptyDots }).map(() => (
                        <span class="inline-block w-[0.82rem] h-[0.82rem] rounded-full border border-[rgba(84,68,112,0.22)] bg-[linear-gradient(135deg,rgba(255,255,255,0.025)_0%,rgba(255,255,255,0.012)_100%)]"></span>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>

            <p class="mt-6 text-sm leading-relaxed text-white/58">
              Un perfil fresco, liviano y despejado, ideal para renovar el clima del espacio
              y acompañar limpiezas suaves sin volver denso el ambiente.
            </p>
          </div>

          <div class="mt-auto border-t border-white/10 pt-5">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="mb-1 text-[10px] uppercase tracking-[0.22em] text-white/30">
                  Acceso
                </p>
                <p class="text-sm text-[#ecdcb8]/90">
                  Próximamente
                </p>
              </div>

              <button
                class="inline-flex items-center justify-center rounded-full border border-[#ecdcb8]/35 px-5 py-2.5 text-sm tracking-[0.06em] text-[#ecdcb8] transition duration-300 hover:border-[#ecdcb8]/55 hover:bg-[#ecdcb8]/10"
              >
                Agregar al carrito
              </button>
            </div>
          </div>
        </aside>
      </div>

      <!-- CARD ESTRATÉGICA INTERMEDIA -->
      <section class="mt-8 rounded-[2rem] border border-white/10 bg-[#120a18]/75 px-6 py-7 backdrop-blur-xl md:px-8">
        <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
          <div>
            <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-white/35">
              Presencia en el espacio
            </p>

            <h2 class="mb-4 text-2xl font-light text-[#ecdcb8] md:text-3xl">
              Un sahumerio claro, herbáceo y respirable
            </h2>

            <p class="mb-4 text-white/72 leading-relaxed">
              Su carácter acompaña limpiezas suaves, aperturas del día, momentos de enfoque y
              pausas conscientes donde hace falta renovar el clima sin invadirlo.
            </p>

            <p class="text-white/62 leading-relaxed">
              Funciona especialmente bien en espacios donde se busca claridad, circulación y una
              sensación más ligera tanto en el ambiente como en la mente.
            </p>
          </div>

          <div class="grid gap-4 rounded-[1.6rem] border border-white/8 bg-white/[0.03] px-5 py-5">
            <div>
              <p class="mb-2 text-[10px] uppercase tracking-[0.22em] text-white/32">
                Carácter
              </p>
              <p class="text-sm leading-relaxed text-white/68">
                Fresco, claro y aireado, con una presencia amable que limpia sin imponerse.
              </p>
            </div>

            <div>
              <p class="mb-2 text-[10px] uppercase tracking-[0.22em] text-white/32">
                Momento ideal
              </p>
              <p class="text-sm leading-relaxed text-white/68">
                Mañanas, reinicios, pausas conscientes o apertura previa a una práctica.
              </p>
            </div>

            <div>
              <p class="mb-2 text-[10px] uppercase tracking-[0.22em] text-white/32">
                Elaboración
              </p>
              <p class="text-sm leading-relaxed text-white/68">
                Elaborado con resinas molidas a mano y hierbas seleccionadas.
              </p>
            </div>

            <div class="pt-2">
              <button
                class="inline-flex items-center justify-center rounded-full border border-white/12 px-5 py-2.5 text-sm tracking-[0.06em] text-white/72 transition duration-300 hover:border-[#ecdcb8]/30 hover:bg-white/[0.04] hover:text-[#ecdcb8]"
              >
                Agregar al carrito
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- DESCRIPCIÓN + PROPIEDADES -->
      <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_0.95fr]">
        <section class="rounded-[2rem] border border-white/10 bg-[#120a18]/75 px-6 py-7 backdrop-blur-xl md:px-8">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-white/35">
            Descripción
          </p>

          <h2 class="mb-5 text-2xl font-light text-[#ecdcb8] md:text-3xl">
            Una presencia herbal que limpia sin invadir
          </h2>

          <div class="space-y-4 text-white/72 leading-relaxed">
            <p>
              Este sahumerio fue pensado para quienes buscan una limpieza sutil pero efectiva,
              capaz de renovar el clima del espacio sin volverlo pesado ni excesivamente intenso.
              Su carácter es fresco, claro y vegetal.
            </p>

            <p>
              La lavanda aporta serenidad y una cualidad envolvente que aquieta. El eucaliptus
              abre, despeja y refresca. La menta introduce una nota viva, ligera y revitalizante.
              Juntas, estas plantas generan una atmósfera que ayuda a cambiar el pulso del lugar
              y también el estado interno de quien lo habita.
            </p>

            <p>
              Puede acompañar una mañana de trabajo, una práctica meditativa, una limpieza del
              hogar o simplemente ese momento en que hace falta cortar con la densidad acumulada
              y volver a respirar con mayor amplitud.
            </p>
          </div>
        </section>

        <section class="rounded-[2rem] border border-white/10 bg-[#120a18]/75 px-6 py-7 backdrop-blur-xl md:px-8">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-white/35">
            Propiedades de la combinación
          </p>

          <div class="space-y-5">
            <div>
              <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                Lavanda
              </h3>
              <p class="text-white/70 leading-relaxed">
                Aporta calma, suavidad y una sensación de cobijo sutil que ayuda a relajar el campo interno.
              </p>
            </div>

            <div>
              <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                Eucaliptus
              </h3>
              <p class="text-white/70 leading-relaxed">
                Despeja, refresca y abre la percepción, generando una impresión de limpieza aérea y renovación.
              </p>
            </div>

            <div>
              <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                Menta
              </h3>
              <p class="text-white/70 leading-relaxed">
                Introduce vitalidad, claridad y una nota estimulante que ayuda a cortar la pesadez ambiental.
              </p>
            </div>

            <div class="border-t border-white/10 pt-4">
              <h3 class="mb-2 text-lg font-medium text-[#ecdcb8]">
                La combinación
              </h3>
              <p class="text-white/70 leading-relaxed">
                El resultado es una alquimia fresca y armonizadora, ideal para limpiar, revitalizar y devolver ligereza al espacio.
              </p>
            </div>
          </div>
        </section>
      </div>

      <!-- VIAJE -->
      <section class="mt-8 rounded-[2rem] border border-[#ecdcb8]/15 bg-[linear-gradient(180deg,rgba(236,220,184,0.08),rgba(255,255,255,0.02))] p-[1px]">
        <div class="rounded-[1.95rem] bg-[#120a18]/80 px-6 py-7 backdrop-blur-xl md:px-8">
          <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-[#ecdcb8]/65">
            Viaje sonoro asociado
          </p>

          <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <div class="max-w-2xl">
              <h2 class="mb-3 text-2xl font-light text-[#ecdcb8] md:text-3xl">
                Niebla Sagrada
              </h2>

              <p class="text-white/72 leading-relaxed">
                Una atmósfera profunda para limpiar el campo energético, soltar cargas y abrir un espacio sutil de protección.
                Esta combinación herbal dialoga especialmente bien con ese viaje.
              </p>
            </div>

            <a
              href="/viajes"
              class="inline-flex items-center justify-center rounded-full border border-[#ecdcb8]/35 px-5 py-2.5 text-sm tracking-[0.06em] text-[#ecdcb8] transition duration-300 hover:border-[#ecdcb8]/55 hover:bg-[#ecdcb8]/10"
            >
              Ver viajes sonoros
            </a>
          </div>
        </div>
      </section>

      <!-- RECOMENDACIONES -->
      <section class="mt-8 rounded-[2rem] border border-white/10 bg-[#120a18]/75 px-6 py-7 backdrop-blur-xl md:px-8">
        <p class="mb-3 text-[11px] uppercase tracking-[0.3em] text-white/35">
          Recomendaciones rituales
        </p>

        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-3 text-xl font-light text-[#ecdcb8]">
              Apertura del día
            </h3>
            <p class="text-white/70 leading-relaxed">
              Encenderlo por la mañana, abrir una ventana unos minutos y dejar que el humo recorra el espacio
              antes de comenzar una actividad importante. Funciona muy bien como gesto de renovación y enfoque.
            </p>
          </div>

          <div>
            <h3 class="mb-3 text-xl font-light text-[#ecdcb8]">
              Limpieza previa a una práctica
            </h3>
            <p class="text-white/70 leading-relaxed">
              Puede usarse antes de meditar, escribir, escuchar un viaje sonoro o simplemente para cambiar la densidad
              de una habitación. No exige una ceremonia compleja: alcanza con presencia, intención y escucha.
            </p>
          </div>
        </div>
      </section>

      <div class="mx-auto mt-12 max-w-2xl text-center">
        <p class="text-sm leading-relaxed text-white/40">
          Cada combinación de Espíritu Sónico busca abrir un clima, no solo perfumar un ambiente.
        </p>
      </div>
    </div>
  </section>
</Layout>